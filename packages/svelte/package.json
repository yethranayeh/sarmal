{
  "name": "@sarmal/svelte",
  "version": "0.1.0",
  "description": "Svelte wrapper for @sarmal/core",
  "keywords": [
    "animation",
    "canvas",
    "curve",
    "loading",
    "parametric",
    "spinner",
    "svg",
    "tanstack-intent"
  ],
  "license": "MIT",
  "author": {
    "name": "Alper Halil",
    "email": "contact@aktasalper.com",
    "url": "https://aktasalper.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yethranayeh/sarmal.git",
    "directory": "packages/svelte"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./src/index.svelte.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/index.svelte.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./Sarmal.svelte": "./src/Sarmal.svelte",
    "./SarmalSVG.svelte": "./src/SarmalSVG.svelte"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@sarmal/core": "workspace:*",
    "@tanstack/intent": "0.0.41",
    "@types/node": "^25.5.2",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.55.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@sarmal/core": "*",
    "svelte": ">=5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
