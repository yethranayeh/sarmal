{
  "name": "@sarmal/core",
  "version": "0.29.0",
  "description": "Curve path based loading indicators and their renderer",
  "keywords": [
    "animation",
    "canvas",
    "curve",
    "loading",
    "parametric",
    "spinner",
    "svg",
    "tanstack-intent"
  ],
  "homepage": "https://sarmal.art",
  "bugs": {
    "url": "https://github.com/yethranayeh/sarmal/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Alper Halil",
    "email": "contact@aktasalper.com",
    "url": "https://aktasalper.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yethranayeh/sarmal.git",
    "directory": "packages/sarmal"
  },
  "bin": {
    "sarmal": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "skills"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/auto-init.*"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./curves": {
      "types": "./dist/curves/index.d.ts",
      "import": "./dist/curves/index.js",
      "require": "./dist/curves/index.cjs"
    },
    "./curves/*": {
      "types": "./dist/curves/*.d.ts",
      "import": "./dist/curves/*.js",
      "require": "./dist/curves/*.cjs"
    },
    "./auto": {
      "import": "./dist/auto-init.js",
      "require": "./dist/auto-init.cjs"
    },
    "./terminal": {
      "node": {
        "import": "./dist/terminal.js",
        "require": "./dist/terminal.cjs"
      },
      "types": "./dist/terminal.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
