{
  "name": "sarmal",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:update": "pnpm --filter e2e exec playwright test --update-snapshots",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "fix": "pnpm -r format && pnpm -r lint"
  },
  "packageManager": "pnpm@9.15.0"
}
