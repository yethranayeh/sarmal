---
interface Props {
	variant?: "default" | "info" | "tip" | "warning" | "error" | "success";
	template?: "solid" | "kanji";
	size?: "sm" | "md";
}

const { variant = "default", template = "solid", size = "md" } = Astro.props;

const config: Record<string, { kanji?: string; color: string }> = {
	default: { color: "var(--color-primary)" },
	info: { kanji: "報", color: "var(--color-primary)" },
	tip: { kanji: "秘", color: "var(--color-accent)" },
	warning: { kanji: "危", color: "var(--color-primary)" },
	error: { kanji: "誤", color: "var(--color-error)" },
	success: { kanji: "達", color: "var(--color-primary)" },
};

const { kanji, color } = config[variant] ?? config.default;
const isDefault = variant === "default";
const bgColor = template === "kanji" ? color : "var(--color-primary)";

const sizeClass =
	size === "sm" ? "w-3.5 h-3.5 text-[10px]" : "w-[18px] h-[18px] text-[12px]";
---

{
	isDefault ? (
		<span
			class:list={[sizeClass, "inline-block shrink-0"]}
			style={`background-color: ${bgColor}`}
		/>
	) : (
		<span
			class:list={[
				sizeClass,
				"inline-flex items-center justify-center shrink-0 font-heading leading-none text-white! select-none",
			]}
			style={`background-color: ${bgColor}`}
		>
			{kanji}
		</span>
	)
}
