---
interface Props {
	variant?: "default" | "info" | "tip" | "warning" | "error" | "success";
	template?: "solid" | "kanji";
	size?: "sm" | "md";
}

const { variant = "default", template = "solid", size = "md" } = Astro.props;

const config: Record<string, { kanji?: string; token: string }> = {
	default: { token: "primary" },
	info: { kanji: "報", token: "primary" },
	tip: { kanji: "秘", token: "accent" },
	warning: { kanji: "危", token: "primary" },
	error: { kanji: "誤", token: "error" },
	success: { kanji: "達", token: "primary" },
};

const { kanji, token } = config[variant] ?? config.default;
const isDefault = variant === "default";
const colorToken = template === "kanji" ? token : "primary";

const colorClasses: Record<string, string> = {
	primary: "bg-primary text-primary-foreground",
	accent: "bg-accent text-accent-foreground",
	error: "bg-error text-error-foreground",
};

const blockClasses = isDefault
	? "bg-primary"
	: (colorClasses[colorToken] ?? "bg-primary text-primary-foreground");

const sizeClass =
	size === "sm" ? "w-3.5 h-3.5 text-[12px]" : "w-[18px] h-[18px] text-[14px]";
---

{
	isDefault ? (
		<span
			class:list={[sizeClass, "block-icon inline-block shrink-0", blockClasses]}
		/>
	) : (
		<span
			class:list={[
				sizeClass,
				"block-icon inline-flex items-center justify-center shrink-0 font-heading leading-none select-none pt-0.5",
				blockClasses,
			]}
		>
			{kanji}
		</span>
	)
}
