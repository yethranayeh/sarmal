---
import Dialog from "./Dialog/Dialog.astro";
import DialogShowcase from "./Dialog/DialogShowcase.astro";
import DialogInfoGrid from "./Dialog/DialogInfoGrid.astro";
import Button from "./Button.astro";

import { SEPARATOR_DOT } from "../variables";
---

<Dialog id='artemis2-modal'>
	<DialogShowcase slot='showcase' canvasId='artemis2-modal-canvas'>
		<div
			slot='top-left'
			class='absolute top-4 left-4 font-mono text-[9px] tracking-widest uppercase text-muted/60 leading-relaxed pointer-events-none'>
			<span class='block'>Artemis II</span>
		</div>
		<div
			slot='bottom-left'
			class='absolute bottom-4 left-4 font-mono text-[8px] text-muted/35 leading-relaxed pointer-events-none'>
			<div class='flex flex-col'>
				<span class='text-primary'>not to scale</span>
				<span>Stylized Approximation</span>
			</div>
		</div>
	</DialogShowcase>

	<div slot='details' class='flex-1 flex flex-col p-6 font-mono text-[11px]'>
		<DialogInfoGrid
			items={[
				{ label: "Launch", value: `Apr 1, 2026 ${SEPARATOR_DOT} 22:35 UTC` },
				{ label: "Crew", value: ["Glover", "Hansen", "Koch", "Wiseman"].join(` ${SEPARATOR_DOT} `) },
				{ label: "Status", value: "", highlight: true, id: "modal-status" },
				{ label: "Progress", value: "", id: "modal-progress" }
			]}
		/>

		<hr class='my-4 w-full border-t-px border-dotted text-muted' />

		<div class='flex-1 flex flex-col'>
			<div class='flex items-center justify-between mb-3'>
				<span class='text-muted/50 uppercase tracking-wider text-[9px]'>Mission timeline</span>
				<div class='flex items-center gap-1'>
					<Button id='modal-mode-auto' variant='ghost' active class='text-[9px] tracking-widest'> Auto </Button>
					<span class='text-muted/30 mx-1'>{SEPARATOR_DOT}</span>
					<Button id='modal-mode-manual' variant='ghost' class='text-[9px] tracking-widest'> Explore </Button>
				</div>
			</div>

			<div id='modal-slider-wrap' class='hidden'>
				<input id='modal-slider' type='range' min='0' max='628' step='1' class='w-full accent-primary cursor-pointer' />
				<div id='modal-debug' class='mt-2 text-[9px] text-muted/50 font-mono'></div>
			</div>

			<div id='modal-milestone-label' class='mt-2 text-[10px] text-muted/70 min-h-10 leading-relaxed'></div>
		</div>

		<div class='border-t border-border/60 pt-3 mt-3 flex items-center justify-between'>
			<span class='text-muted/50 uppercase tracking-widest text-[9px]'
				>Artemis II {SEPARATOR_DOT} <span class='text-primary'>Integrity</span></span
			>
			<button
				id='artemis2-modal-close'
				class='font-mono text-[9px] tracking-widest uppercase text-muted/50 hover:text-foreground transition-colors cursor-pointer'>
				Close
			</button>
		</div>
	</div>
</Dialog>

<script>
	import { createSarmal, curves } from "@sarmal/core";
	import { SEPARATOR_DOT } from "../variables";

	const LAUNCH = new Date("2026-04-01T22:35:12Z").getTime();
	const SPLASHDOWN = new Date("2026-04-11T00:21:00Z").getTime();
	const TWO_PI = Math.PI * 2;
	const TOTAL_HOURS = (SPLASHDOWN - LAUNCH) / (1000 * 60 * 60);
	const LIVE_T = 5.92;

	const dialog = document.getElementById("artemis2-modal") as HTMLDialogElement;
	const canvas = document.getElementById("artemis2-modal-canvas") as HTMLCanvasElement;
	const statusEl = document.getElementById("modal-status") as HTMLElement;
	const progressEl = document.getElementById("modal-progress") as HTMLElement;
	const sliderWrap = document.getElementById("modal-slider-wrap") as HTMLElement;
	const slider = document.getElementById("modal-slider") as HTMLInputElement;
	const milestoneEl = document.getElementById("modal-milestone-label") as HTMLElement;
	const openBtn = document.getElementById("artemis2-details") as HTMLButtonElement;
	const closeBtn = document.getElementById("artemis2-modal-close") as HTMLButtonElement;
	const btnAuto = document.getElementById("modal-mode-auto") as HTMLButtonElement;
	const btnExplore = document.getElementById("modal-mode-manual") as HTMLButtonElement;

	const milestones = [
		{ label: "Launch", t: 0, note: `Liftoff from Kennedy Space Center, Launch Complex 39B. ${SEPARATOR_DOT} Apr 1` },
		{
			label: "TLI Burn",
			t: (30 / TOTAL_HOURS) * TWO_PI,
			note: `Orion's main engine fires for 5 min 50 sec. Crew leaves Earth orbit and begins the journey to the Moon. ${SEPARATOR_DOT} NASA, Apr 2`
		},
		{
			label: "Halfway to Moon",
			t: (50 / TOTAL_HOURS) * TWO_PI,
			note: `Lock in, we're Moonbound. Crew is more than halfway to their destination, preparations for lunar flyby underway. ${SEPARATOR_DOT} NASA, Apr 4`,
			source: { url: "https://x.com/NASA/status/2040393011616452726", label: "NASA" }
		},
		{
			label: "Sphere of Influence",
			t: 1.95,
			note: `Outbound correction burn complete (17.5 sec). Orion enters the Moon's sphere of gravitational influence ${SEPARATOR_DOT} lunar gravity now dominates the trajectory. ${SEPARATOR_DOT} NASA`
		},
		{
			label: "Distance Record",
			t: 2.56,
			note: `The 54-year-old Apollo 13 record — 248,655 miles from Earth — was surpassed at 17:56 UTC by the Artemis II crew aboard Orion.`,
			source: { url: "https://x.com/NASAArtemis/status/2041216809748013274", label: "NASA Artemis" }
		},
		{
			label: "Closest Approach",
			t: 3.17,
			note: `Closest approach: 6,000 miles above the surface. Free-return trajectory around the far side of the Moon. ${SEPARATOR_DOT} Apr 6`
		},
		{
			label: "Far Side Blackout",
			t: 3.1,
			note: `Orion passes behind the Moon. ~45 minutes of communication blackout with Mission Control. ${SEPARATOR_DOT} Apr 6`
		},
		{
			label: "Slingshot Maneuver",
			t: 3.9,
			note: `Free-return trajectory set. Orion uses lunar gravity to slingshot back toward Earth. ${SEPARATOR_DOT} Apr 7`
		},
		{
			label: "Radiation Test",
			t: (192 / TOTAL_HOURS) * TWO_PI,
			note: `Van Allen belt passage. Crew collects radiation shielding data for future deep space missions. ${SEPARATOR_DOT} Apr 9`
		},
		{
			label: "Reentry Prep",
			t: (216 / TOTAL_HOURS) * TWO_PI,
			note: `Final day preparations. Crew reviews landing procedures, stows equipment. ${SEPARATOR_DOT} Apr 10`
		},
		{
			label: "CM/SM Separation",
			t: (232 / TOTAL_HOURS) * TWO_PI,
			note: `Crew module separates from service module. The final descent begins. ${SEPARATOR_DOT} Apr 11`
		},
		{ label: "Splashdown", t: TWO_PI, note: `Pacific Ocean splashdown. Mission complete. ${SEPARATOR_DOT} Apr 11` }
	];

	let sarmal: ReturnType<typeof createSarmal> | null = null;
	let initialized = false;
	let mode: "auto" | "explore" = "auto";

	function computeMissionState() {
		const elapsed = Date.now() - LAUNCH;
		const elapsedHours = elapsed / (1000 * 60 * 60);
		const dayNumber = Math.floor(elapsed / (1000 * 60 * 60 * 24));
		return { elapsedHours, dayNumber };
	}

	function nearestMilestone(t: number) {
		return milestones.reduce((closest, m) => (Math.abs(m.t - t) < Math.abs(closest.t - t) ? m : closest));
	}

	function updateMilestoneLabel(t: number) {
		const m = nearestMilestone(t);
		const THRESHOLD = TWO_PI * 0.03;
		if (Math.abs(m.t - t) < THRESHOLD) {
			const sourceHtml =
				"source" in m && m.source
					? ` <a href="${m.source.url}" target="_blank" rel="noopener noreferrer" class="text-primary underline underline-offset-2">${m.source.label}</a>`
					: "";
			milestoneEl.innerHTML = `${m.label} ${SEPARATOR_DOT} ${m.note}${sourceHtml}`;
		} else {
			milestoneEl.textContent = "";
		}
		document.getElementById("modal-debug")!.textContent =
			`t=${t.toFixed(4)} | elapsed=${((t / TWO_PI) * TOTAL_HOURS).toFixed(2)}h`;
	}

	function seekAndFreeze(t: number) {
		sarmal!.seek(t);
		sarmal!.play();
		sarmal!.pause();
	}

	function setMode(newMode: "auto" | "explore") {
		mode = newMode;

		if (newMode === "auto") {
			btnAuto.classList.add("text-primary");
			btnAuto.classList.remove("text-muted");
			btnExplore.classList.add("text-muted");
			btnExplore.classList.remove("text-primary");
			sliderWrap.classList.add("hidden");
			milestoneEl.textContent = "";
		} else {
			btnExplore.classList.add("text-primary");
			btnExplore.classList.remove("text-muted");
			btnAuto.classList.add("text-muted");
			btnAuto.classList.remove("text-primary");
			sliderWrap.classList.remove("hidden");
		}
	}

	function openModal() {
		dialog.showModal();

		const { elapsedHours, dayNumber } = computeMissionState();

		statusEl.textContent = elapsedHours >= TOTAL_HOURS ? "Complete" : `In flight ${SEPARATOR_DOT} Day ${dayNumber}`;
		const elapsedPercentage = Math.round((elapsedHours / TOTAL_HOURS) * 100);
		const timeRemainingHours = Math.round(TOTAL_HOURS - elapsedHours);
		progressEl.textContent = `${elapsedPercentage}% ${SEPARATOR_DOT} ${timeRemainingHours}h remaining`;

		if (!initialized) {
			sarmal = createSarmal(canvas, curves.artemis2, {
				trailColor: "#60a5fa",
				skeletonColor: "#1b1c1a",
				headColor: "#60a5fa",
				trailLength: 300
			});

			initialized = true;
		}

		setMode("auto");

		sarmal!.reset();
		sarmal!.play();

		const liveMissionT = LIVE_T;
		slider.value = String(Math.round(liveMissionT * 100));
	}

	btnAuto.addEventListener("click", () => {
		if (mode === "auto") {
			return;
		}
		setMode("auto");

		sarmal!.reset();
		sarmal!.play();
		milestoneEl.textContent = "";
	});

	btnExplore.addEventListener("click", () => {
		if (mode === "explore") {
			return;
		}

		sarmal!.pause();

		slider.value = String(Math.round(LIVE_T * 100));

		seekAndFreeze(LIVE_T);
		updateMilestoneLabel(LIVE_T);
		setMode("explore");
	});

	slider.addEventListener("input", () => {
		const t = Number(slider.value) / 100;

		seekAndFreeze(t);
		updateMilestoneLabel(t);
	});

	openBtn?.addEventListener("click", openModal);
	closeBtn.addEventListener("click", () => dialog.close());
	dialog.addEventListener("click", (e) => {
		if (e.target === dialog) dialog.close();
	});
</script>
