---
interface Props {
	id: string;
	checked?: boolean;
	label?: string;
	class?: string;
}

const { id, checked = true, label, class: className } = Astro.props;
---

<div class:list={["flex items-center justify-between", className]}>
	{
		label && (
			<label
				for={id}
				class="font-mono text-xs tracking-wider uppercase text-muted"
			>
				{label}
			</label>
		)
	}
	<button
		id={id}
		class="w-10 h-5 rounded-full relative transition-colors"
		class:list={[checked ? "bg-foreground" : "bg-muted"]}
		role="switch"
		aria-checked={checked}
		data-checked={checked}
	>
		<span
			class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-background transition-transform"
			class:list={[checked ? "translate-x-5" : "translate-x-0"]}></span>
	</button>
</div>
