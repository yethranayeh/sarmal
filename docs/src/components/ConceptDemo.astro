---
interface Props {
	layout?: "side" | "bottom";
}

const { layout = "side" } = Astro.props;
---

{
	layout === "side" && (
		<div
			data-ctx="concept-demo"
			class="concept-demo my-6 flex max-w-150 bg-surface border border-border rounded-lg overflow-hidden"
		>
			<div class="flex-1 relative min-w-0">
				<slot name="view" />
			</div>
			<div class="w-42 shrink-0 border-l border-border-subtle bg-background py-4.5 px-4 flex flex-col justify-between gap-4">
				<div class="text-[0.63rem] text-muted-foreground leading-[1.85] font-mono">
					<slot name="info" />
				</div>
				<slot name="controls" />
			</div>
		</div>
	)
}

{
	layout === "bottom" && (
		<div
			data-ctx="concept-demo"
			class="concept-demo my-6 max-w-125 bg-surface border border-border rounded-lg overflow-hidden"
		>
			<div class="relative">
				<slot name="view" />
			</div>
			<div class="border-t border-border-subtle bg-background py-2.5 px-3.5 flex items-center gap-3">
				<div class="flex-1 flex flex-col gap-1 min-w-0 text-[0.68rem] text-muted-foreground font-mono">
					<slot name="info" />
				</div>
				<slot name="controls" />
			</div>
		</div>
	)
}

<style is:global>
	.cdemo-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		flex-shrink: 0;
		transition:
			background 0.3s ease,
			box-shadow 0.3s ease;
	}

	.cdemo-dot[data-state="playing"] {
		background: var(--color-primary);
		box-shadow: 0 0 7px
			color-mix(in srgb, var(--color-primary) 50%, transparent);
	}

	.cdemo-dot[data-state="paused"] {
		background: var(--color-muted);
		box-shadow: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.cdemo-dot[data-state="playing"] {
			animation: cdemo-pulse-dot 2.2s ease-in-out infinite;
		}
	}

	@keyframes cdemo-pulse-dot {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
	}

	.cdemo-btn {
		padding: 0.375rem 0.75rem;
		font-size: 0.68rem;
		font-family: ui-monospace, "SF Mono", monospace;
		border-radius: 0.125rem;
		cursor: pointer;
		transition:
			color 0.15s,
			background 0.15s,
			border-color 0.15s,
			filter 0.15s;
		white-space: nowrap;
		letter-spacing: 0.01em;
	}

	.cdemo-btn-ghost {
		background: transparent;
		color: var(--color-muted-foreground);
		border: 1px solid var(--color-border);
	}

	.cdemo-btn-ghost:hover {
		border-color: var(--color-muted);
		color: var(--color-foreground);
	}

	.cdemo-btn-ghost:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.cdemo-btn-play {
		background: var(--color-primary);
		color: var(--color-primary-foreground);
		border: 1px solid var(--color-accent);
	}

	.cdemo-btn-play:hover {
		filter: brightness(1.1);
	}

	.cdemo-btn-danger {
		background: color-mix(in srgb, var(--color-error) 15%, transparent);
		color: var(--color-error);
		border: 1px solid color-mix(in srgb, var(--color-error) 28%, transparent);
	}

	.cdemo-btn-danger:hover {
		background: color-mix(in srgb, var(--color-error) 22%, transparent);
	}

	.cdemo-btn-danger:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.concept-demo code {
		color: var(--color-primary);
		background: var(--color-surface);
		padding: 1px 5px !important;
		border-radius: 2px;
		border: none !important;
		font-size: 0.6rem;
	}
</style>

<script>
	import type { SarmalInstance } from "@sarmal/core";

	document
		.querySelectorAll<HTMLElement>(".concept-demo")
		.forEach((container) => {
			container.addEventListener("sarmal:ready", (e: Event) => {
				const instance = (e as CustomEvent<{ instance: SarmalInstance }>).detail
					.instance;

				// Infer initial playing state from the blueprint in the view slot
				const blueprint =
					container.querySelector<HTMLElement>(".sarmal-blueprint");
				let isPlaying = blueprint?.dataset.autoStart !== "false";

				const dot = container.querySelector<HTMLElement>("[data-sarmal-dot]");
				const stateText = container.querySelector<HTMLElement>(
					"[data-sarmal-state-text]",
				);

				function updateUI() {
					if (dot) dot.dataset.state = isPlaying ? "playing" : "paused";
					if (stateText)
						stateText.textContent = isPlaying ? "playing" : "paused";
					container
						.querySelectorAll<HTMLButtonElement>(
							'[data-sarmal-action="toggle"]',
						)
						.forEach((btn) => {
							btn.textContent = isPlaying ? "Pause" : "Play";
							btn.classList.toggle("cdemo-btn-ghost", isPlaying);
							btn.classList.toggle("cdemo-btn-play", !isPlaying);
						});
				}

				updateUI();

				container
					.querySelectorAll<HTMLElement>("[data-sarmal-action]")
					.forEach((el) => {
						el.addEventListener("click", () => {
							switch (el.dataset.sarmalAction) {
								case "play":
									instance.play();
									isPlaying = true;
									updateUI();
									break;
								case "pause":
									instance.pause();
									isPlaying = false;
									updateUI();
									break;
								case "toggle":
									void (isPlaying ? instance.pause() : instance.play());
									isPlaying = !isPlaying;
									updateUI();
									break;
								case "reset":
									instance.reset();
									if (dot) dot.dataset.state = "paused";
									if (stateText) stateText.textContent = "reset";
									setTimeout(updateUI, 600);
									break;
								case "destroy": {
									instance.destroy();
									isPlaying = false;
									if (dot) dot.dataset.state = "paused";
									if (stateText) stateText.textContent = "destroyed";
									const btn = el as HTMLButtonElement;
									btn.disabled = true;
									btn.textContent = "Destroyed";
									break;
								}
							}
						});
					});
			});
		});
</script>
