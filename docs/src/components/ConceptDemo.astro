---
interface Props {
	layout?: "side" | "bottom";
}

const { layout = "side" } = Astro.props;
---

{
	layout === "side" && (
		<div
			data-ctx='concept-demo'
			class='concept-demo my-6 flex max-w-150 bg-foreground border border-[#2e2f2c] rounded-lg overflow-hidden'>
			<div class='flex-1 relative min-w-0'>
				<slot name='view' />
			</div>
			<div class='w-42 shrink-0 border-l border-[#242522] bg-[#131412] py-4.5 px-4 flex flex-col justify-between gap-4'>
				<div class='text-[0.63rem] text-[#b3ada7] leading-[1.85] font-mono'>
					<slot name='info' />
				</div>
				<slot name='controls' />
			</div>
		</div>
	)
}

{
	layout === "bottom" && (
		<div
			data-ctx='concept-demo'
			class='concept-demo my-6 max-w-125 bg-foreground border border-[#2e2f2c] rounded-lg overflow-hidden'>
			<div class='relative'>
				<slot name='view' />
			</div>
			<div class='border-t border-[#242522] bg-[#131412] py-2.5 px-3.5 flex items-center gap-3'>
				<div class='flex-1 flex flex-col gap-1 min-w-0 text-[0.68rem] font-mono'>
					<slot name='info' />
				</div>
				<slot name='controls' />
			</div>
		</div>
	)
}

<style is:global>
	.cdemo-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		flex-shrink: 0;
		transition:
			background 0.3s ease,
			box-shadow 0.3s ease;
	}

	.cdemo-dot[data-state="playing"] {
		background: #ffffff;
		box-shadow: 0 0 7px rgb(192 20 60 / 0.5);
	}

	.cdemo-dot[data-state="paused"] {
		background: #5c5752;
		box-shadow: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.cdemo-dot[data-state="playing"] {
			animation: cdemo-pulse-dot 2.2s ease-in-out infinite;
		}
	}

	@keyframes cdemo-pulse-dot {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
	}

	.cdemo-btn {
		padding: 0.375rem 0.75rem;
		font-size: 0.68rem;
		font-family: ui-monospace, "SF Mono", monospace;
		border-radius: 0.125rem;
		cursor: pointer;
		transition:
			color 0.15s,
			background 0.15s,
			border-color 0.15s,
			filter 0.15s;
		white-space: nowrap;
		letter-spacing: 0.01em;
	}

	.cdemo-btn-ghost {
		background: transparent;
		color: #b3ada7;
		border: 1px solid #2e2f2c;
	}

	.cdemo-btn-ghost:hover {
		border-color: #3e3f3b;
		color: var(--color-background);
	}

	.cdemo-btn-ghost:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.cdemo-btn-play {
		background: var(--color-primary);
		color: #ffffff;
		border: 1px solid var(--color-accent);
	}

	.cdemo-btn-play:hover {
		filter: brightness(1.1);
	}

	.cdemo-btn-danger {
		background: hsl(0 45% 14%);
		color: hsl(0 65% 62%);
		border: 1px solid hsl(0 45% 24%);
	}

	.cdemo-btn-danger:hover {
		background: hsl(0 45% 18%);
	}

	.cdemo-btn-danger:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.concept-demo code {
		color: #e0566e;
		background: #242522;
		padding: 1px 5px !important;
		border-radius: 2px;
		border: none !important;
		font-size: 0.6rem;
	}
</style>

<script>
	import type { SarmalInstance } from "@sarmal/core";

	document.querySelectorAll<HTMLElement>(".concept-demo").forEach((container) => {
		container.addEventListener("sarmal:ready", (e: Event) => {
			const instance = (e as CustomEvent<{ instance: SarmalInstance }>).detail.instance;

			// Infer initial playing state from the blueprint in the view slot
			const blueprint = container.querySelector<HTMLElement>(".sarmal-blueprint");
			let isPlaying = blueprint?.dataset.autoStart !== "false";

			const dot = container.querySelector<HTMLElement>("[data-sarmal-dot]");
			const stateText = container.querySelector<HTMLElement>("[data-sarmal-state-text]");

			function updateUI() {
				if (dot) dot.dataset.state = isPlaying ? "playing" : "paused";
				if (stateText) stateText.textContent = isPlaying ? "playing" : "paused";
				container.querySelectorAll<HTMLButtonElement>('[data-sarmal-action="toggle"]').forEach((btn) => {
					btn.textContent = isPlaying ? "Pause" : "Play";
					btn.classList.toggle("cdemo-btn-ghost", isPlaying);
					btn.classList.toggle("cdemo-btn-play", !isPlaying);
				});
			}

			updateUI();

			container.querySelectorAll<HTMLElement>("[data-sarmal-action]").forEach((el) => {
				el.addEventListener("click", () => {
					switch (el.dataset.sarmalAction) {
						case "play":
							instance.play();
							isPlaying = true;
							updateUI();
							break;
						case "pause":
							instance.pause();
							isPlaying = false;
							updateUI();
							break;
						case "toggle":
							void (isPlaying ? instance.pause() : instance.play());
							isPlaying = !isPlaying;
							updateUI();
							break;
						case "reset":
							instance.reset();
							if (dot) dot.dataset.state = "paused";
							if (stateText) stateText.textContent = "reset";
							setTimeout(updateUI, 600);
							break;
						case "destroy": {
							instance.destroy();
							isPlaying = false;
							if (dot) dot.dataset.state = "paused";
							if (stateText) stateText.textContent = "destroyed";
							const btn = el as HTMLButtonElement;
							btn.disabled = true;
							btn.textContent = "Destroyed";
							break;
						}
					}
				});
			});
		});
	});
</script>
