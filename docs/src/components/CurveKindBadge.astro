---
import { Waypoints, Pi } from "@lucide/astro";

interface Props {
	kind: "parametric" | "drawn";
}

const { kind } = Astro.props;

const isDrawn = kind === "drawn";
const label = isDrawn ? "Drawn" : "Parametric";
const Icon = isDrawn ? Waypoints : Pi;
---

<span
	class="inline-flex items-center gap-1 font-ui text-xs tracking-wider capitalize text-accent border border-border bg-surface-raised rounded-full px-2 py-px select-none align-middle"
>
	<Icon size={14} />
	<span>{label}</span>
</span>
