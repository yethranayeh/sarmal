---
import Branding from "./Branding.astro";

interface NavLink {
	href: string;
	label: string;
	external?: boolean;
	active?: boolean;
}

interface Props {
	links?: NavLink[];
}

const { links = [] } = Astro.props;

const defaultLinks: NavLink[] = [{ href: "/play", label: "Playground" }];

const navLinks = links.length > 0 ? links : defaultLinks;
const currentPath = Astro.url.pathname;
---

<header class='bg-surface-raised w-full px-4 py-2 flex items-center justify-between border-b border-border'>
	<Branding />
	<nav class='flex items-center gap-4'>
		{
			navLinks.map((link) => {
				const isActive = link.active ?? link.href === currentPath;
				const colorClass = isActive ? "text-primary" : "text-muted";
				return (
					<a
						href={link.href}
						target={link.external ? "_blank" : undefined}
						rel={link.external ? "noopener noreferrer" : undefined}
						class={`group font-mono text-xs tracking-wider uppercase ${colorClass} hover:text-foreground transition-colors`}>
						<span class='opacity-20 group-hover:opacity-100 transition-opacity'>{"["}</span>
						<span>{link.label}</span>
						<span class='opacity-20 group-hover:opacity-100 transition-opacity'>{"]"}</span>
					</a>
				);
			})
		}
	</nav>
</header>
