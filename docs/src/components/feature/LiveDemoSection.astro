---
import { Check } from "@lucide/astro";
---

<style>
	.scenario-panel {
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}
	.scenario-panel.active {
		opacity: 1;
		pointer-events: auto;
	}

	.step-dot {
		width: 38px;
		height: 38px;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		overflow: hidden;
		transition:
			border-color 0.4s,
			background 0.4s;
		flex-shrink: 0;
	}
	.step-dot svg {
		display: block;
	}
	.step-dot.done {
		background: rgba(74, 222, 128, 0.07);
		border-color: rgba(74, 222, 128, 0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 16px;
		color: #4ade80;
	}

	.chat-thinking-area {
		transition:
			opacity 0.45s ease,
			transform 0.45s ease;
	}
	.chat-thinking-area.exiting {
		opacity: 0;
		transform: translateY(-10px);
		pointer-events: none;
	}

	.chat-response {
		opacity: 0;
		transform: translateY(8px);
		transition:
			opacity 0.4s ease,
			transform 0.4s ease;
	}
	.chat-response.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.dash-metric-value {
		transition: color 0.5s;
	}
</style>

<section class='w-full bg-foreground py-6 md:py-12'>
	<div class='max-w-3xl mx-auto px-4 flex flex-col items-center gap-10'>
		<div class='flex items-center gap-4 w-full'>
			<div class='flex-1 h-px bg-white/10'></div>
			<span class='font-mono text-[10px] tracking-[0.25em] uppercase text-background/50'>Live demo</span>
			<div class='flex-1 h-px bg-white/10'></div>
		</div>

		<div class='w-full max-w-sm flex flex-col items-center gap-4'>
			<div
				id='live-demo-card'
				class='relative w-full bg-[#232420] border border-white/[0.07] rounded-xl overflow-hidden'
				style='min-height: 200px'>
				<!-- Scenario 1: Multi-step Pipeline -->
				<div id='scenario-pipeline' class='scenario-panel absolute space-y-4 inset-0 p-8 flex flex-col justify-center'>
					<p class='font-mono text-[9px] tracking-[0.25em] uppercase' style='color: rgba(255,255,255,0.25)'>
						Processing
					</p>
					<div class='flex flex-col'>
						<div class='flex items-start gap-3'>
							<div class='flex flex-col items-center'>
								<div class='step-dot' id='pipe-dot-0'></div>
								<div class='w-px h-3 bg-white/10'></div>
							</div>
							<span
								class='font-body text-[13px] pt-2.5 leading-none transition-colors duration-300'
								id='pipe-label-0'
								style='color: rgba(255,255,255,0.3)'>Parsing files</span
							>
						</div>
						<div class='flex items-start gap-3'>
							<div class='flex flex-col items-center'>
								<div class='step-dot' id='pipe-dot-1'></div>
								<div class='w-px h-3 bg-white/10'></div>
							</div>
							<span
								class='font-body text-[13px] pt-2.5 leading-none transition-colors duration-300'
								id='pipe-label-1'
								style='color: rgba(255,255,255,0.3)'>Analysing patterns</span
							>
						</div>
						<div class='flex items-start gap-3'>
							<div class='step-dot' id='pipe-dot-2'></div>
							<span
								class='font-body text-[13px] pt-2.5 leading-none transition-colors duration-300'
								id='pipe-label-2'
								style='color: rgba(255,255,255,0.3)'>Generating output</span
							>
						</div>
					</div>
				</div>

				<!-- Scenario 2: AI Chat -->
				<div id='scenario-chat' class='scenario-panel absolute inset-0 p-8 flex flex-col justify-center gap-3'>
					<div
						class='self-end font-body text-[13px] px-3.5 py-2 rounded-[14px_14px_4px_14px]'
						style='background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.75); max-width: 82%'>
						Summarise this document
					</div>
					<div class='chat-thinking-area flex flex-col items-start gap-1.5' id='chat-thinking-area'>
						<div id='chat-sarmal-slot' class='w-14 h-14'></div>
						<span class='font-mono text-[11px] tracking-widest' style='color: rgba(255,255,255,0.28)'>Thinking…</span>
					</div>
					<div
						class='chat-response self-start font-body text-[13px] leading-relaxed px-3.5 py-2.5 rounded-[14px_14px_14px_4px]'
						id='chat-response'
						style='background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.72); max-width: 90%; display: none'>
					</div>
				</div>

				<!-- Scenario 3: File Upload -->
				<div id='scenario-upload' class='scenario-panel absolute inset-0 p-8 flex flex-col justify-center gap-4'>
					<div class='relative flex items-center justify-center' style='min-height: 88px'>
						<div class='flex flex-col items-center gap-2 absolute' id='upload-spinner-area'>
							<div id='upload-sarmal-slot' style='width:60px;height:60px'></div>
							<span class='font-body text-[12px]' id='upload-status-text' style='color: rgba(255,255,255,0.4)'
								>Uploading…</span
							>
						</div>
						<div class='flex-col items-center gap-1.5 absolute' id='upload-done-area' style='display: none'>
							<Check size={20} class='text-green-400' />

							<span class='font-body text-[13px] font-medium' style='color: rgba(255,255,255,0.7)'>Upload complete</span
							>
							<span class='font-mono text-[11px]' style='color: rgba(255,255,255,0.3)'>2 files · 3.3 MB</span>
						</div>
					</div>
					<div class='flex flex-col gap-1.5 w-full'>
						<div class='flex items-center gap-2 px-2.5 py-1.5 rounded-lg' style='background: rgba(255,255,255,0.03)'>
							<span class='text-sm'>📄</span>
							<span class='flex-1 truncate font-body text-[11px]' style='color: rgba(255,255,255,0.5)'
								>quarterly-report.pdf</span
							>
							<Check id='upload-fc-1' size={12} class='transition-colors duration-300' />
						</div>
						<div class='flex items-center gap-2 px-2.5 py-1.5 rounded-lg' style='background: rgba(255,255,255,0.03)'>
							<span class='text-sm'>🖼️</span>
							<span class='flex-1 truncate font-body text-[11px]' style='color: rgba(255,255,255,0.5)'
								>hero-banner.png</span
							>
							<Check id='upload-fc-2' size={12} class='transition-colors duration-300' />
						</div>
					</div>
				</div>

				<!-- Scenario 4: Dashboard Metrics -->
				<div id='scenario-dashboard' class='scenario-panel absolute inset-0 p-6 flex flex-col justify-center'>
					<div class='flex gap-3'>
						<div
							class='flex-1 flex flex-col gap-2 p-3.5 rounded-xl'
							style='background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07)'>
							<div id='dash-slot-0' style='width:52px;height:52px'></div>
							<div class='font-mono text-[10px] tracking-[0.04em]' style='color: rgba(255,255,255,0.3)'>
								Active Users
							</div>
							<div
								class='dash-metric-value font-heading text-xl font-semibold leading-none'
								id='dash-val-0'
								style='color: rgba(255,255,255,0.15); letter-spacing: -0.02em'>
								—
							</div>
						</div>
						<div
							class='flex-1 flex flex-col gap-2 p-3.5 rounded-xl'
							style='background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07)'>
							<div id='dash-slot-1' style='width:52px;height:52px'></div>
							<div class='font-mono text-[10px] tracking-[0.04em]' style='color: rgba(255,255,255,0.3)'>Revenue</div>
							<div
								class='dash-metric-value font-heading text-xl font-semibold leading-none'
								id='dash-val-1'
								style='color: rgba(255,255,255,0.15); letter-spacing: -0.02em'>
								—
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Pagination dots -->
			<div id='live-demo-dots' class='flex gap-2'></div>
		</div>
	</div>
</section>

<script>
	import { createSarmalSVG, curves, palettes } from "@sarmal/core";

	type Instance = ReturnType<typeof createSarmalSVG>;

	function stop(s: Instance | null, slot: HTMLElement): null {
		s?.pause();
		slot.innerHTML = "";
		return null;
	}

	function contentDuration(): number {
		return 2000 + Math.floor(Math.random() * 2000);
	}

	const SLIDES = [
		{ id: "pipeline", color: "#2dd4bf" },
		{ id: "chat", color: "#a78bfa" },
		{ id: "upload", color: "#fb923c" },
		{ id: "dashboard", color: "#38bdf8" }
	] as const;

	// ── Dots ──────────────────────────────────────────────────────────────
	const dotsEl = document.getElementById("live-demo-dots")!;
	SLIDES.forEach(() => {
		const dot = document.createElement("span");
		dot.className = "w-1.5 h-1.5 rounded-full transition-all duration-300";
		dot.style.backgroundColor = "rgba(255,255,255,0.15)";
		dotsEl.appendChild(dot);
	});
	const dots = Array.from(dotsEl.querySelectorAll("span")) as HTMLElement[];

	function setActiveDot(i: number) {
		dots.forEach((d, j) => {
			if (j === i) {
				d.style.backgroundColor = SLIDES[j].color;
				d.style.transform = "scale(1.4)";
				d.style.opacity = "0.85";
			} else {
				d.style.backgroundColor = "rgba(255,255,255,0.15)";
				d.style.transform = "scale(1)";
				d.style.opacity = "1";
			}
		});
	}

	// ── Scenario 1: Pipeline ──────────────────────────────────────────────
	const PIPE_STEPS = [
		{ dotId: "pipe-dot-0", labelId: "pipe-label-0", curve: curves.lissajous43, color: "#2dd4bf", speed: 2.5 },
		{ dotId: "pipe-dot-1", labelId: "pipe-label-1", curve: curves.rose3, color: "#a78bfa", speed: 1.5 },
		{ dotId: "pipe-dot-2", labelId: "pipe-label-2", curve: curves.epitrochoid7, color: "#2dd4bf", speed: 2 }
	];
	let pipeSarmals: (Instance | null)[] = [null, null, null];
	let pipeGen = 0;
	let pipeTimer: ReturnType<typeof setTimeout> | null = null;

	function pipelineCleanup() {
		pipeGen++;
		if (pipeTimer) {
			clearTimeout(pipeTimer);
			pipeTimer = null;
		}
		PIPE_STEPS.forEach((step, i) => {
			const dot = document.getElementById(step.dotId) as HTMLElement;
			pipeSarmals[i] = stop(pipeSarmals[i], dot);
			dot.className = "step-dot";
			dot.textContent = "";
			(document.getElementById(step.labelId) as HTMLElement).style.color = "rgba(255,255,255,0.3)";
		});
	}

	function pipelineStart(onDone: () => void) {
		pipelineCleanup();
		const gen = pipeGen;

		function activateStep(i: number) {
			if (pipeGen !== gen) return;
			const step = PIPE_STEPS[i]!;
			const dot = document.getElementById(step.dotId) as HTMLElement;
			const label = document.getElementById(step.labelId) as HTMLElement;

			label.style.color = "rgba(255,255,255,0.85)";
			pipeSarmals[i] = createSarmalSVG(dot, step.curve, {
				trailColor: step.color,
				skeletonColor: "transparent",
				headColor: step.color,
				headRadius: 1.5,
				trailLength: 70
			});
			pipeSarmals[i]!.setSpeed(step.speed);

			pipeTimer = setTimeout(() => {
				if (pipeGen !== gen) return;
				pipeSarmals[i] = stop(pipeSarmals[i], dot);
				dot.className = "step-dot done";
				dot.textContent = "✓";
				label.style.color = "rgba(255,255,255,0.4)";

				if (i < PIPE_STEPS.length - 1) {
					pipeTimer = setTimeout(() => activateStep(i + 1), 300);
				} else {
					onDone();
				}
			}, 1400);
		}

		activateStep(0);
	}

	// ── Scenario 2: Chat ──────────────────────────────────────────────────
	let chatSarmal: Instance | null = null;
	let chatGen = 0;
	let chatTimer: ReturnType<typeof setTimeout> | null = null;
	let chatTicker: ReturnType<typeof setInterval> | null = null;
	const CHAT_RESPONSE = "Three key findings, all pointing to strong Q1 growth across every segment.";

	function chatCleanup() {
		chatGen++;
		if (chatTimer) {
			clearTimeout(chatTimer);
			chatTimer = null;
		}
		if (chatTicker) {
			clearInterval(chatTicker);
			chatTicker = null;
		}
		const chatSlot = document.getElementById("chat-sarmal-slot") as HTMLElement;
		chatSarmal = stop(chatSarmal, chatSlot);
		const thinkingArea = document.getElementById("chat-thinking-area") as HTMLElement;
		const chatResponse = document.getElementById("chat-response") as HTMLElement;
		thinkingArea.classList.remove("exiting");
		thinkingArea.style.display = "flex";
		chatResponse.classList.remove("visible");
		chatResponse.style.display = "none";
		chatResponse.textContent = "";
	}

	function chatStart(onDone: () => void) {
		chatCleanup();
		const gen = chatGen;
		const chatSlot = document.getElementById("chat-sarmal-slot") as HTMLElement;
		const thinkingArea = document.getElementById("chat-thinking-area") as HTMLElement;
		const chatResponse = document.getElementById("chat-response") as HTMLElement;

		chatSarmal = createSarmalSVG(chatSlot, curves.lissajous43, {
			skeletonColor: "transparent",
			trailColor: palettes.bard,
			trailStyle: "gradient-animated",
			headRadius: 1.5,
			trailLength: 65
		});

		chatTimer = setTimeout(() => {
			if (chatGen !== gen) return;
			thinkingArea.classList.add("exiting");
			chatSarmal = stop(chatSarmal, chatSlot);

			chatTimer = setTimeout(() => {
				if (chatGen !== gen) return;
				thinkingArea.style.display = "none";
				chatResponse.style.display = "block";

				requestAnimationFrame(() => {
					chatResponse.classList.add("visible");
					let i = 0;
					chatTicker = setInterval(() => {
						if (chatGen !== gen) {
							clearInterval(chatTicker!);
							return;
						}
						chatResponse.textContent = CHAT_RESPONSE.slice(0, ++i);
						if (i >= CHAT_RESPONSE.length) {
							clearInterval(chatTicker!);
							chatTicker = null;
							onDone();
						}
					}, 26);
				});
			}, 450);
		}, 2400);
	}

	// ── Scenario 3: Upload ────────────────────────────────────────────────
	let uploadSarmal: Instance | null = null;
	let uploadGen = 0;
	let uploadTimers: ReturnType<typeof setTimeout>[] = [];

	function uploadCleanup() {
		uploadGen++;
		uploadTimers.forEach((t) => clearTimeout(t));
		uploadTimers = [];
		const uploadSlot = document.getElementById("upload-sarmal-slot") as HTMLElement;
		uploadSarmal = stop(uploadSarmal, uploadSlot);
		(document.getElementById("upload-spinner-area") as HTMLElement).style.display = "flex";
		(document.getElementById("upload-done-area") as HTMLElement).style.display = "none";
		(document.getElementById("upload-status-text") as HTMLElement).textContent = "Uploading…";
		(document.getElementById("upload-fc-1") as HTMLElement).style.color = "rgba(74,222,128,0)";
		(document.getElementById("upload-fc-2") as HTMLElement).style.color = "rgba(74,222,128,0)";
	}

	function uploadStart(onDone: () => void) {
		uploadCleanup();
		const gen = uploadGen;
		const uploadSlot = document.getElementById("upload-sarmal-slot") as HTMLElement;
		const spinnerArea = document.getElementById("upload-spinner-area") as HTMLElement;
		const doneArea = document.getElementById("upload-done-area") as HTMLElement;
		const statusText = document.getElementById("upload-status-text") as HTMLElement;
		const fc1 = document.getElementById("upload-fc-1") as HTMLElement;
		const fc2 = document.getElementById("upload-fc-2") as HTMLElement;

		uploadSarmal = createSarmalSVG(uploadSlot, curves.rose5, {
			trailColor: "#fb923c",
			skeletonColor: "rgba(251,146,60,0.07)",
			headColor: "#fb923c",
			headRadius: 2,
			trailLength: 80
		});

		uploadTimers.push(
			setTimeout(() => {
				if (uploadGen !== gen) return;
				fc1.style.color = "rgba(74,222,128,0.8)";
				statusText.textContent = "Almost there…";
			}, 1800)
		);

		uploadTimers.push(
			setTimeout(() => {
				if (uploadGen !== gen) return;
				fc2.style.color = "rgba(74,222,128,0.8)";
			}, 2800)
		);

		uploadTimers.push(
			setTimeout(() => {
				if (uploadGen !== gen) return;
				uploadSarmal = stop(uploadSarmal, uploadSlot);
				spinnerArea.style.display = "none";
				doneArea.style.display = "flex";
				onDone();
			}, 3600)
		);
	}

	// ── Scenario 4: Dashboard ─────────────────────────────────────────────
	const DASH_ITEMS = [
		{ slotId: "dash-slot-0", valId: "dash-val-0", curve: curves.epitrochoid7, color: "#38bdf8", value: "12.4k" },
		{ slotId: "dash-slot-1", valId: "dash-val-1", curve: curves.rose5, color: "#4ade80", value: "$84.2k" }
	];
	let dashSarmals: (Instance | null)[] = [null, null];
	let dashGen = 0;
	let dashTimers: ReturnType<typeof setTimeout>[] = [];

	function dashCleanup() {
		dashGen++;
		dashTimers.forEach((t) => clearTimeout(t));
		dashTimers = [];
		DASH_ITEMS.forEach((item, i) => {
			const slot = document.getElementById(item.slotId) as HTMLElement;
			const valEl = document.getElementById(item.valId) as HTMLElement;
			dashSarmals[i] = stop(dashSarmals[i], slot);
			valEl.textContent = "—";
			valEl.style.color = "rgba(255,255,255,0.15)";
		});
	}

	function dashStart(onDone: () => void) {
		dashCleanup();
		const gen = dashGen;

		DASH_ITEMS.forEach((item, i) => {
			const slot = document.getElementById(item.slotId) as HTMLElement;
			dashSarmals[i] = createSarmalSVG(slot, item.curve, {
				trailColor: item.color,
				skeletonColor: "rgba(255,255,255,0.05)",
				headColor: item.color,
				headRadius: 2,
				trailLength: 80
			});
		});

		DASH_ITEMS.forEach((item, i) => {
			dashTimers.push(
				setTimeout(
					() => {
						if (dashGen !== gen) return;
						const slot = document.getElementById(item.slotId) as HTMLElement;
						const valEl = document.getElementById(item.valId) as HTMLElement;
						dashSarmals[i] = stop(dashSarmals[i], slot);
						valEl.textContent = item.value;
						valEl.style.color = "rgba(255,255,255,0.85)";
						if (i === DASH_ITEMS.length - 1) onDone();
					},
					2200 + i * 450
				)
			);
		});
	}

	// ── Main cycle ────────────────────────────────────────────────────────
	const SCENARIO_RUNNERS = [pipelineStart, chatStart, uploadStart, dashStart] as const;

	let idx = 0;
	let mainTimer: ReturnType<typeof setTimeout> | null = null;

	function showSlide(i: number) {
		if (mainTimer) {
			clearTimeout(mainTimer);
			mainTimer = null;
		}
		pipelineCleanup();
		chatCleanup();
		uploadCleanup();
		dashCleanup();

		document.querySelectorAll<HTMLElement>(".scenario-panel").forEach((el) => el.classList.remove("active"));
		document.getElementById(`scenario-${SLIDES[i].id}`)!.classList.add("active");
		setActiveDot(i);

		SCENARIO_RUNNERS[i](() => {
			mainTimer = setTimeout(() => {
				idx = (i + 1) % SLIDES.length;
				showSlide(idx);
			}, contentDuration());
		});
	}

	const card = document.getElementById("live-demo-card")!;
	const observer = new IntersectionObserver(
		(entries) => {
			if (entries[0]?.isIntersecting) {
				observer.disconnect();
				showSlide(0);
			}
		},
		{ threshold: 0.1 }
	);
	observer.observe(card);
</script>
