---
import { BookText, FlaskConical } from "@lucide/astro";

export interface NavLink {
	href: string;
	label: string;
	external?: boolean;
	active?: boolean;
	icon: typeof BookText;
}
interface Props {
	links?: NavLink[];
}

const { links = [] } = Astro.props;

const defaultLinks: NavLink[] = [
	{ href: "/docs", label: "Docs", icon: BookText },
	{ href: "/play", label: "Playground", icon: FlaskConical },
];

const navLinks = links.length > 0 ? links : defaultLinks;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<nav class="flex items-center gap-4">
	{
		navLinks.map((link) => {
			const isActive = link.active ?? link.href === currentPath;
			const colorClass = isActive ? "text-primary" : "text-muted";
			const Icon = link.icon;
			return (
				<a
					href={link.href}
					target={link.external ? "_blank" : undefined}
					rel={link.external ? "noopener noreferrer" : undefined}
					class:list={[
						"inline-flex items-center gap-1 font-ui text-xs tracking-wider uppercase hover:text-foreground transition-colors",
						colorClass,
					]}
				>
					<Icon size={16} />
					<span>{link.label}</span>
				</a>
			);
		})
	}
</nav>
