---
import type { CurveDef, Point } from "@sarmal/core";

import { createEngine, computeBoundaries, curves } from "@sarmal/core";

import CurveKindBadge from "../../CurveKindBadge.astro";

import { CURVE_DOCS } from "../../../data/curves";
import { STANDARD_CURVES, ICONIC_CURVES } from "../../../data/curve-catalog";

interface Props {
	section: "standard" | "iconic";
}

function toSVGPath(
	pts: Array<Point>,
	scale: number,
	ox: number,
	oy: number,
): string {
	if (pts.length < 2) {
		return "";
	}

	return (
		pts
			.map(
				(p, i) =>
					`${i === 0 ? "M" : "L"}${(p.x * scale + ox).toFixed(2)} ${(p.y * scale + oy).toFixed(2)}`,
			)
			.join(" ") + " Z"
	);
}

// ! getSarmalSkeleton() uses ~50 pts/unit which is too dense at 52px.
function sampleClean(curveDef: CurveDef): Array<Point> {
	const period = curveDef.period ?? Math.PI * 2;
	const n = Math.ceil(period * 15);
	const sample = curveDef.skeletonFn
		? (phase: number) => curveDef.skeletonFn!(phase)
		: (phase: number) => curveDef.fn(phase, 0, {});

	return Array.from({ length: n }, (_, i) => sample((i / (n - 1)) * period));
}

function geometricPathLength(pts: Point[], scale: number): number {
	let len = 0;
	for (let i = 1; i < pts.length; i++) {
		const dx = (pts[i].x - pts[i - 1].x) * scale;
		const dy = (pts[i].y - pts[i - 1].y) * scale;
		len += Math.sqrt(dx * dx + dy * dy);
	}
	return len;
}

const { section } = Astro.props;
const ids = section === "standard" ? STANDARD_CURVES : ICONIC_CURVES;

const BASE_MS = 800;
const MAX_MS = 2000;

const entriesWithDuration = ids.map((id) => {
	const meta = CURVE_DOCS[id];
	const curveDef = curves[id];

	const engine = createEngine(curveDef);
	const ptsHiRes = engine.getSarmalSkeleton(); // used for accurate bounds only
	const ptsClean = sampleClean(curveDef);
	const b = computeBoundaries(ptsHiRes, 100, 100, 8);
	const d = b ? toSVGPath(ptsClean, b.scale, b.offsetX, b.offsetY) : "";
	const pathLen = b ? geometricPathLength(ptsClean, b.scale) : 0;

	return {
		id,
		name: meta.name,
		family: meta.family,
		description: meta.description,
		color: meta.color,
		d,
		pathLen,
	};
});

const lengths = entriesWithDuration.map((e) => e.pathLen).filter((l) => l > 0);
const minLen = Math.min(...lengths);
const maxLen = Math.max(...lengths);
const isSameLength = minLen === maxLen;

const entries = entriesWithDuration.map(({ pathLen, ...rest }) => {
	let duration: number;

	if (pathLen <= 0) {
		duration = BASE_MS;
	} else if (isSameLength) {
		duration = Math.round((BASE_MS + MAX_MS) / 2);
	} else {
		const ratio = Math.log(pathLen / minLen) / Math.log(maxLen / minLen);
		duration = Math.round(BASE_MS + ratio * (MAX_MS - BASE_MS));
	}
	return { ...rest, duration };
});
---

<div
	class:list={[
		"not-prose mt-4 grid gap-4",
		{
			"lg:grid-cols-2": entries.length > 1, // TODO: should not be conditional after a new iconic curve is added to the library
		},
	]}
	data-glow-grid
>
	{
		entries.map(({ id, name, family, description, color, d, duration }) => (
			<a
				href={`/docs/curves/${id}/`}
				class="glow-card curve-catalog-card relative overflow-hidden no-underline select-none active:scale-[0.98] transition ring-1 ring-border bg-surface-raised/25"
				style={`--curve-color: ${color}; --draw-duration: ${duration}ms`}
				data-glow-card
			>
				<div class="glow-inner relative flex size-full overflow-hidden">
					<div class="glow-icon-layer pointer-events-none absolute inset-0 flex items-center justify-center will-change-[transform]">
						<svg
							aria-hidden="true"
							viewBox="0 0 100 100"
							class="glow-svg size-20"
						>
							<circle cx="50" cy="50" r="42" class="glow-fill" />
							<path class="glow-path" d={d} />
						</svg>
					</div>

					<div class="z-1 relative flex items-center gap-4 p-4 flex-1">
						<div class="h-13 w-13 shrink-0 overflow-hidden rounded-md border border-border bg-background">
							<svg
								aria-label={`Drawing of ${name} curve`}
								viewBox="0 0 100 100"
								class="block h-full w-full"
							>
								<path class="path-skeleton" d={d} pathLength="1" />
								<path class="path-draw" d={d} pathLength="1" />
							</svg>
						</div>
						<div class="min-w-0 w-full flex flex-col">
							<div class="flex gap-1 justify-between">
								<span class="font-heading leading-none text-[14px] font-medium text-foreground">
									{name}
								</span>
								<CurveKindBadge
									kind={
										section === "standard" ? "parametric" : "drawn" // TODO: this only works for current state. There is no guarantee that standard ones will not have drawn curves or iconic ones will not have parametric ones
									}
								/>
							</div>
							<span class="font-mono leading-none text-[9px] tracking-widest uppercase text-muted">
								{family}
							</span>
							<p class="mt-1.5 font-body text-[12px] leading-relaxed text-muted">
								{description}
							</p>
						</div>
					</div>
				</div>

				<div class="glow-border pointer-events-none absolute inset-0" />
			</a>
		))
	}
</div>

<style>
	/* Glow effects appropriated from https://chanhdai.com/components/glow-card-grid */
	/* .glow-inner {
		clip-path: inset(0 round var(--card-radius, 16px));
	} */

	.glow-icon-layer {
		--move-x: calc(var(--pointer-x, -10) * 50%);
		--move-y: calc(var(--pointer-y, -10) * 50%);
		transform: translate(var(--move-x), var(--move-y))
			scale(var(--card-icon-scale, 4));
		filter: blur(var(--card-icon-blur, 25px))
			brightness(var(--card-icon-brightness, 1.3))
			saturate(var(--card-icon-saturate, 5));
		opacity: var(--card-icon-opacity, 0.3);
	}

	.glow-fill {
		fill: var(--curve-color);
		opacity: 0.7;
	}

	.glow-path {
		fill: none;
		stroke: var(--curve-color);
		stroke-width: 3;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.glow-border {
		border: var(--card-border-width, 3px) solid transparent;
		/* border-radius: var(--card-radius, 16px); */
		/* clip-path: inset(0 round var(--card-radius, 16px)); */
		mask-image: linear-gradient(#fff 0 100%), linear-gradient(#fff 0 100%);
		mask-origin: border-box, padding-box;
		mask-clip: border-box, padding-box;
		mask-composite: exclude;
		-webkit-mask-composite: xor;
		backdrop-filter: blur(var(--card-border-blur, 10px))
			brightness(var(--card-border-brightness, 2.5))
			contrast(var(--card-border-contrast, 2.5))
			saturate(var(--card-border-saturate, 4.2));
	}

	.path-skeleton,
	.path-draw {
		fill: none;
		stroke-width: 2.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-dasharray: 1 2;
	}

	.path-skeleton {
		stroke: var(--color-muted);
		stroke-dashoffset: 0;
		opacity: 0.45;
	}

	.path-draw {
		stroke: var(--curve-color);
		stroke-dashoffset: 1;
		opacity: 0.9;
		transition: stroke-dashoffset 400ms ease;
	}

	@media (prefers-reduced-motion: reduce) {
		.path-draw {
			stroke-dashoffset: 0;
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		.curve-catalog-card:hover .path-draw {
			stroke-dashoffset: 0;
			transition-duration: var(--draw-duration, 1200ms);
			transition-timing-function: cubic-bezier(0.76, 0, 0.24, 1);
		}
	}

	@media (max-width: 767px) and (prefers-reduced-motion: no-preference) {
		.scroll-draw .path-draw {
			stroke-dashoffset: 0;
			transition-duration: var(--draw-duration, 1200ms);
			transition-timing-function: cubic-bezier(0.76, 0, 0.24, 1);
		}
	}
</style>

<script>
	function setupScrollDraw() {
		const mq = window.matchMedia(
			"(max-width: 767px) and (prefers-reduced-motion: no-preference)",
		);
		if (!mq.matches) return;

		const cards = document.querySelectorAll(".curve-catalog-card");
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("scroll-draw");
						observer.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.3 },
		);

		for (const card of cards) {
			observer.observe(card);
		}
	}

	function setupGlow() {
		const grids = document.querySelectorAll("[data-glow-grid]");
		if (grids.length === 0) return;

		document.addEventListener("pointermove", (event) => {
			for (const grid of grids) {
				const cards: NodeListOf<HTMLElement> =
					grid.querySelectorAll("[data-glow-card]");
				cards.forEach((card) => {
					const rect = card.getBoundingClientRect();
					const centerX = rect.left + rect.width / 2;
					const centerY = rect.top + rect.height / 2;
					const x = (event.clientX - centerX) / (rect.width / 2);
					const y = (event.clientY - centerY) / (rect.height / 2);
					card.style.setProperty("--pointer-x", x.toFixed(3));
					card.style.setProperty("--pointer-y", y.toFixed(3));
				});
			}
		});
	}

	setupScrollDraw();
	setupGlow();
</script>
