---
// AI Chat thinking state
---

<div
	data-scenario="chat"
	class="absolute inset-0 p-8 flex flex-col justify-center gap-3 opacity-0 transition-opacity duration-400 pointer-events-none [&.active]:opacity-100 [&.active]:pointer-events-auto"
>
	<div
		class="self-end font-body text-[13px] px-3.5 py-2 rounded-[14px_14px_4px_14px] bg-surface text-foreground max-w-[82%]"
	>
		Summarise this document
	</div>
	<div
		data-chat-thinking
		class="flex flex-col items-start gap-1.5 transition-all duration-450 ease-out [&.exiting]:opacity-0 [&.exiting]:-translate-y-2.5 [&.exiting]:pointer-events-none"
	>
		<svg data-chat-slot class="w-14 h-14"></svg>
		<span class="font-ui text-[11px] tracking-widest text-muted">Thinking…</span
		>
	</div>
	<div
		data-chat-response
		class="self-start font-body text-[13px] leading-relaxed px-3.5 py-2.5 rounded-[14px_14px_14px_4px] opacity-0 translate-y-2 transition-all duration-400 ease-out bg-surface text-muted-foreground max-w-[90%] hidden [&.visible]:opacity-100 [&.visible]:translate-y-0"
	>
	</div>
</div>

<script>
	import { createSarmalSVG, curves, palettes } from "@sarmal/core";
	import type { DemoScenarioAPI } from "../../../lib/demo";

	type Instance = ReturnType<typeof createSarmalSVG>;

	function stop(s: Instance | null, slot: SVGSVGElement): null {
		s?.pause();
		slot.innerHTML = "";
		return null;
	}

	const CHAT_RESPONSE =
		"Three key findings, all pointing to strong Q1 growth across every segment.";

	function initChat(container: HTMLElement): DemoScenarioAPI {
		let chatSarmal: Instance | null = null;
		let chatGen = 0;
		let chatTimer: ReturnType<typeof setTimeout> | null = null;
		let chatTicker: ReturnType<typeof setInterval> | null = null;

		function cleanup() {
			chatGen++;
			if (chatTimer) {
				clearTimeout(chatTimer);
				chatTimer = null;
			}
			if (chatTicker) {
				clearInterval(chatTicker);
				chatTicker = null;
			}
			const chatSlot = container.querySelector(
				"[data-chat-slot]",
			) as SVGSVGElement;
			chatSarmal = stop(chatSarmal, chatSlot);
			const thinkingArea = container.querySelector(
				"[data-chat-thinking]",
			) as HTMLElement;
			const chatResponse = container.querySelector(
				"[data-chat-response]",
			) as HTMLElement;
			thinkingArea.classList.remove("exiting", "hidden");
			chatResponse.classList.remove("visible");
			chatResponse.classList.add("hidden");
			chatResponse.textContent = "";
		}

		function start(onDone: () => void) {
			cleanup();
			const gen = chatGen;
			const chatSlot = container.querySelector(
				"[data-chat-slot]",
			) as SVGSVGElement;
			const thinkingArea = container.querySelector(
				"[data-chat-thinking]",
			) as HTMLElement;
			const chatResponse = container.querySelector(
				"[data-chat-response]",
			) as HTMLElement;

			chatSarmal = createSarmalSVG(chatSlot, curves.lissajous43, {
				skeletonColor: "transparent",
				trailColor: palettes.bard,
				trailStyle: "gradient-animated",
				headRadius: 1.5,
				trailLength: 65,
			});

			chatTimer = setTimeout(() => {
				if (chatGen !== gen) return;
				thinkingArea.classList.add("exiting");
				chatSarmal = stop(chatSarmal, chatSlot);

				chatTimer = setTimeout(() => {
					if (chatGen !== gen) return;
					thinkingArea.classList.add("hidden");
					chatResponse.classList.remove("hidden");

					requestAnimationFrame(() => {
						chatResponse.classList.add("visible");
						let i = 0;
						chatTicker = setInterval(() => {
							if (chatGen !== gen) {
								clearInterval(chatTicker!);
								return;
							}
							chatResponse.textContent = CHAT_RESPONSE.slice(0, ++i);
							if (i >= CHAT_RESPONSE.length) {
								clearInterval(chatTicker!);
								chatTicker = null;
								onDone();
							}
						}, 26);
					});
				}, 450);
			}, 2400);
		}

		return { start, cleanup };
	}

	// Register on DOM ready
	const container = document.querySelector(
		'[data-scenario="chat"]',
	) as HTMLElement;
	if (container) {
		window.demoRegistry = window.demoRegistry || {};
		window.demoRegistry["chat"] = initChat(container);
	}
</script>
