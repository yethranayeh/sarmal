---

---

<div
	data-scenario="dashboard"
	class="absolute inset-0 p-6 flex flex-col justify-center opacity-0 transition-opacity duration-400 pointer-events-none [&.active]:opacity-100 [&.active]:pointer-events-auto"
>
	<div class="flex gap-3">
		<div
			class="flex-1 flex flex-col gap-2 p-3.5 rounded-xl bg-surface border border-border"
		>
			<svg data-dash-slot="0" class="w-13 h-13"></svg>
			<div class="font-ui text-[10px] tracking-[0.04em] text-muted">
				Active Users
			</div>
			<div
				data-dash-val="0"
				class="transition-colors duration-500 font-heading text-xl font-semibold leading-none text-muted tracking-[-0.02em]"
			>
				—
			</div>
		</div>
		<div
			class="flex-1 flex flex-col gap-2 p-3.5 rounded-xl bg-surface border border-border"
		>
			<svg data-dash-slot="1" class="w-13 h-13"></svg>
			<div class="font-ui text-[10px] tracking-[0.04em] text-muted">
				Revenue
			</div>
			<div
				data-dash-val="1"
				class="transition-colors duration-500 font-heading text-xl font-semibold leading-none text-muted tracking-[-0.02em]"
			>
				—
			</div>
		</div>
	</div>
</div>

<script>
	import { createSarmalSVG, curves } from "@sarmal/core";
	import type { DemoScenarioAPI } from "../../../lib/demo";

	type Instance = ReturnType<typeof createSarmalSVG>;

	function stop(s: Instance | null, slot: SVGSVGElement): null {
		s?.pause();
		slot.innerHTML = "";
		return null;
	}

	const DASH_ITEMS = [
		{
			slotSelector: "[data-dash-slot='0']",
			valSelector: "[data-dash-val='0']",
			curve: curves.epitrochoid7,
			color: "#38bdf8",
			value: "12.4k",
		},
		{
			slotSelector: "[data-dash-slot='1']",
			valSelector: "[data-dash-val='1']",
			curve: curves.rose5,
			color: "#4ade80",
			value: "$84.2k",
		},
	];

	function initDashboard(container: HTMLElement): DemoScenarioAPI {
		let dashSarmals: (Instance | null)[] = [null, null];
		let dashGen = 0;
		let dashTimers: ReturnType<typeof setTimeout>[] = [];

		function cleanup() {
			dashGen++;
			dashTimers.forEach((t) => clearTimeout(t));
			dashTimers = [];
			DASH_ITEMS.forEach((item, i) => {
				const slot = container.querySelector(
					item.slotSelector,
				) as SVGSVGElement;
				const valEl = container.querySelector(item.valSelector) as HTMLElement;
				dashSarmals[i] = stop(dashSarmals[i], slot);
				valEl.textContent = "—";
				valEl.classList.remove("text-foreground");
				valEl.classList.add("text-muted");
			});
		}

		function start(onDone: () => void) {
			cleanup();
			const gen = dashGen;

			DASH_ITEMS.forEach((item, i) => {
				const slot = container.querySelector(
					item.slotSelector,
				) as SVGSVGElement;
				dashSarmals[i] = createSarmalSVG(slot, item.curve, {
					trailColor: item.color,
					skeletonColor: "rgba(255,255,255,0.05)",
					headColor: item.color,
					headRadius: 2,
					trailLength: 80,
				});
			});

			DASH_ITEMS.forEach((item, i) => {
				dashTimers.push(
					setTimeout(
						() => {
							if (dashGen !== gen) return;
							const slot = container.querySelector(
								item.slotSelector,
							) as SVGSVGElement;
							const valEl = container.querySelector(
								item.valSelector,
							) as HTMLElement;
							dashSarmals[i] = stop(dashSarmals[i], slot);
							valEl.textContent = item.value;
							valEl.classList.remove("text-muted");
							valEl.classList.add("text-foreground");
							if (i === DASH_ITEMS.length - 1) onDone();
						},
						2200 + i * 450,
					),
				);
			});
		}

		return { start, cleanup };
	}

	// Register on DOM ready
	const container = document.querySelector(
		'[data-scenario="dashboard"]',
	) as HTMLElement;
	if (container) {
		window.demoRegistry = window.demoRegistry || {};
		window.demoRegistry["dashboard"] = initDashboard(container);
	}
</script>
