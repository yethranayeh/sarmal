---
import type { TrailStyle, PalettePreset } from "@sarmal/core";
import { curves } from "@sarmal/core";
import { codeToHtml } from "shiki";

import Button from "../Button.astro";
import Sarmal from "../Sarmal.astro";
import UnifiedCurveDialog from "../UnifiedCurveDialog.astro";
import MorphDetailModal from "../MorphDetailModal.astro";
import InfoCard from "../InfoCard.astro";

import sarmalTheme from "../../themes/sarmal-editorial.json";
import sarmalDarkTheme from "../../themes/sarmal-editorial-dark.json";
import { curveMetadata } from "../../data/curveMetadata";
import DotGrid from "../DotGrid.astro";

interface CurveConfig {
	id: keyof typeof curves;
	name: string;
	color: string;
	trailStyle?: TrailStyle;
	palette?: PalettePreset;
	trailLength?: number;
	headColor?: string;
}

const sarmalCurves: CurveConfig[] = [
	{ id: "rose3", name: "Rose (n=3)", color: "#e879f9" },
	{
		id: "deltoid",
		name: "Deltoid",
		color: "#fb923c",
		trailStyle: "gradient-animated",
		palette: "ocean",
		trailLength: 200,
		headColor: "#22d3ee"
	},
	{
		id: "astroid",
		name: "Astroid",
		color: "#38bdf8",
		trailStyle: "gradient-animated",
		palette: "bard",
		trailLength: 200,
		headColor: "#a855f7"
	},
	{
		id: "epitrochoid7",
		name: "Epitrochoid",
		color: "#a78bfa",
		trailStyle: "gradient-static",
		palette: "fire",
		headColor: "#fbbf24"
	},
	{
		id: "rose5",
		name: "Rose (n=5)",
		color: "#f472b6",
		trailStyle: "gradient-static",
		palette: "sunset",
		headColor: "#f472b6"
	},
	{
		id: "lissajous43",
		name: "Lissajous 4:3",
		color: "#2dd4bf",
		trailStyle: "gradient-static",
		palette: "forest",
		headColor: "#86efac"
	}
];

const morphPairs = [
	{ from: "astroid", to: "deltoid", color: "#38bdf8" },
	{ from: "rose3", to: "epitrochoid7", color: "#e879f9" },
	{ from: "lissajous32", to: "rose5", color: "#fb923c" },
	{ from: "lame", to: "astroid", color: "#a78bfa" }
] as const;

const curveDataWithHighlight = await Promise.all(
	sarmalCurves.map(async (curve) => {
		const metadata = curveMetadata[curve.id];
		const curveDef = curves[curve.id];

		const period =
			typeof curveDef.period === "number"
				? curveDef.period === Math.PI * 2
					? "2π"
					: curveDef.period.toFixed(2)
				: "2π";

		const codeText = `<canvas data-sarmal="${curve.id}"></canvas>`;

		const codeHtml = await codeToHtml(codeText, {
			lang: "html",
			themes: {
				light: sarmalTheme as { name: string },
				dark: sarmalDarkTheme as { name: string }
			}
		});

		return {
			...curve,
			name: metadata.name,
			family: metadata.family,
			period,
			equation: metadata.equation,
			description: metadata.description,
			codeText,
			codeHtml
		};
	})
);
---

<div id='demo-section' class='flex flex-col md:flex-row justify-center gap-4 md:gap-8 lg:gap-12 p-2 sm:p-6 mx-auto'>
	<InfoCard label='Standard Sarmals'>
		<div class='grid grid-cols-2 sm:grid-cols-3 gap-4'>
			{
				curveDataWithHighlight.map((curve) => (
					<div class='flex flex-col items-center'>
						<div title={curve.id} class='relative content-auto rounded-lg p-4 mb-2 overflow-visible'>
						<Sarmal
							curve={curve.id}
							width={80}
							height={80}
							trailColor={curve.color}
							lazy
							trailStyle={curve.trailStyle}
							palette={curve.palette}
							trailLength={curve.trailLength}
							headColor={curve.headColor}
						/>
							<DotGrid />
						</div>
						<span title={curve.id} class='font-mono text-[10px] tracking-wider uppercase text-muted'>
							{curve.name}
						</span>
						<button
							data-curve-trigger
							data-curve-id={curve.id}
							data-code-text={curve.codeText}
							data-code-html={curve.codeHtml}
							data-metadata-json={JSON.stringify({
								name: curve.name,
								family: curve.family,
								period: curve.period,
								equation: curve.equation,
								description: curve.description,
								color: curve.color
							})}
							class='font-mono text-[9px] tracking-widest uppercase text-muted hover:text-foreground transition-colors cursor-pointer mt-1'>
							Details
						</button>
					</div>
				))
			}
		</div>
	</InfoCard>

	<InfoCard label='Morphing Sarmals'>
		<div class='grid grid-cols-2 sm:grid-cols-4 md:grid-cols-2 gap-4'>
			{
				morphPairs.map((pair) => (
					<div class='flex flex-col items-center'>
						<div class='relative'>
							<div
								id={`morph-${pair.from}-${pair.to}`}
								data-color={pair.color}
								title={`${pair.from} -> ${pair.to}`}
								class=' content-auto rounded-lg p-4 mb-2 overflow-visible'
							/>
							<DotGrid />
						</div>
						<span class='font-mono text-[10px] tracking-wider uppercase text-muted'>
							{pair.from}
							{"->"}
							{pair.to}
						</span>
						<Button id={`morph-${pair.from}-${pair.to}-details`} variant='ghost' class='text-[9px] mt-1'>
							Details
						</Button>
					</div>
				))
			}
		</div>
	</InfoCard>
</div>

{morphPairs.map((pair) => <MorphDetailModal fromId={pair.from} toId={pair.to} />)}
<UnifiedCurveDialog />

<script>
	import type { TrailStyle, PalettePreset } from "@sarmal/core";
	import { createSarmal, curves } from "@sarmal/core";

	const MORPH_DURATION = 800;
	const HOLD_DURATION = 2400;
	const WARMUP_DURATION = 1500;

	interface MorphPair {
		from: string;
		to: string;
		color: string;
	}

	async function runMorphLoop(canvas: HTMLCanvasElement, pair: MorphPair): Promise<void> {
		const fromCurve = curves[pair.from as keyof typeof curves];
		const toCurve = curves[pair.to as keyof typeof curves];

		if (!fromCurve || !toCurve) {
			return;
		}

		const sarmal = createSarmal(canvas, fromCurve, {
			trailColor: pair.color,
			skeletonColor: pair.color,
			headColor: pair.color,
			trailLength: 60
		});

		sarmal.start();
		await new Promise((resolve) => setTimeout(resolve, WARMUP_DURATION));

		while (true) {
			await sarmal.setSpeedOver(0.3, 300);
			await sarmal.morphTo(toCurve, { duration: MORPH_DURATION });
			await sarmal.setSpeedOver(1.0, 400);
			await new Promise((resolve) => setTimeout(resolve, HOLD_DURATION));
			await sarmal.setSpeedOver(0.3, 300);
			await sarmal.morphTo(fromCurve, { duration: MORPH_DURATION });
			await sarmal.setSpeedOver(1.0, 400);
			await new Promise((resolve) => setTimeout(resolve, HOLD_DURATION));
		}
	}

	function initDemoSection(section: Element): void {
		// lazy sarmals are not picked up by auto-init
		section.querySelectorAll<HTMLCanvasElement>("canvas[data-sarmal-lazy]").forEach((canvas) => {
			const curveName = canvas.dataset.sarmalLazy;
			if (!curveName) {
				return;
			}
			const curve = curves[curveName as keyof typeof curves];
			if (!curve) {
				return;
			}
			const sarmal = createSarmal(canvas, curve, {
				...(canvas.dataset.trailColor && { trailColor: canvas.dataset.trailColor }),
				...(canvas.dataset.skeletonColor && { skeletonColor: canvas.dataset.skeletonColor }),
				...(canvas.dataset.headColor && { headColor: canvas.dataset.headColor }),
				...(canvas.dataset.headRadius && { headRadius: parseFloat(canvas.dataset.headRadius) }),
				...(canvas.dataset.trailLength && { trailLength: parseInt(canvas.dataset.trailLength, 10) }),
				...(canvas.dataset.trailStyle && { trailStyle: canvas.dataset.trailStyle as TrailStyle }),
				...(canvas.dataset.palette && { palette: canvas.dataset.palette as PalettePreset })
			});
			sarmal.start();
		});

		section.querySelectorAll<HTMLDivElement>("div[id^='morph-']").forEach((container) => {
			const idMatch = container.id.match(/^morph-(.+)-(.+)$/);
			if (!idMatch) {
				return;
			}

			const fromId = idMatch[1]!;
			const toId = idMatch[2]!;
			const color = container.dataset.color ?? "#c0143c";

			const canvas = document.createElement("canvas");
			canvas.width = 80;
			canvas.height = 80;
			canvas.className = "w-[80px] h-[80px]";
			container.innerHTML = "";
			container.appendChild(canvas);

			runMorphLoop(canvas, { from: fromId, to: toId, color }).catch(() => {});
		});
	}

	const section = document.getElementById("demo-section")!;
	const observer = new IntersectionObserver(
		(entries) => {
			if (entries[0]?.isIntersecting) {
				observer.disconnect();
				initDemoSection(section);
			}
		},
		{ threshold: 0.1 }
	);
	observer.observe(section);
</script>
