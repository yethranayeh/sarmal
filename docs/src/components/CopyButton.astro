---
import { Copy, Check } from "@lucide/astro";

interface Props {
	code: string;
	"data-copy-btn"?: string;
	variant?: "ghost" | "ghost-inverted";
	class?: string;
}

const {
	code,
	"data-copy-btn": dataAttr,
	variant = "ghost-inverted",
	class: className,
} = Astro.props;
---

<button
	data-copy-btn={dataAttr ?? ""}
	data-code={code}
	title="Copy"
	class:list={[
		"copy-btn relative cursor-pointer transition-colors p-1 size-5.5",
		{
			"text-foreground/70 hover:text-foreground dark:text-white/50 dark:hover:text-white":
				variant === "ghost-inverted",
			"text-muted hover:text-foreground": variant !== "ghost-inverted",
		},
		className,
	]}
>
	<Copy class="copy-icon absolute inset-0 m-auto" size={14} />
	<Check
		class="check-icon absolute inset-0 m-auto"
		size={14}
		stroke-width={2.5}
	/>
</button>

<style>
	.copy-icon,
	.check-icon {
		transition:
			opacity 0.2s ease,
			transform 0.2s ease,
			filter 0.2s ease;
	}

	.copy-icon {
		opacity: 1;
		transform: scale(1);
		filter: blur(0px);
	}

	.check-icon {
		opacity: 0;
		transform: scale(0.6);
		filter: blur(4px);
	}

	.copy-btn[data-copied] .copy-icon {
		opacity: 0;
		transform: scale(0.6);
		filter: blur(4px);
	}

	.copy-btn[data-copied] .check-icon {
		opacity: 1;
		transform: scale(1);
		filter: blur(0px);
	}
</style>

<script>
	document.querySelectorAll("[data-copy-btn]").forEach((btn) => {
		btn.addEventListener("click", async () => {
			const code = btn.getAttribute("data-code");
			if (code) {
				await navigator.clipboard.writeText(code);
				btn.setAttribute("data-copied", "");
				setTimeout(() => btn.removeAttribute("data-copied"), 2000);
			}
		});
	});
</script>
