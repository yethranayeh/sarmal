---
import SectionLabel from "./SectionLabel.astro";

interface Props {
	label: string;
}

const { label } = Astro.props;
---

<section class='space-y-6 rounded-2xl p-2 overflow-hidden bg-surface-raised shadow-xs'>
	<div class='border-b border-surface p-2 w-full'>
		<SectionLabel label={label} />
	</div>

	<slot />
</section>
