---
import Dialog from "./Dialog/Dialog.astro";
import DialogShowcase from "./Dialog/DialogShowcase.astro";
import DialogInfoGrid from "./Dialog/DialogInfoGrid.astro";
---

<Dialog id="unified-curve-dialog">
	<DialogShowcase slot="showcase" canvasId="unified-curve-canvas">
		<div
			slot="top-left"
			class="absolute top-4 left-4 font-ui text-[9px] tracking-widest uppercase text-muted/60 leading-relaxed pointer-events-none"
		>
			<span id="dialog-curve-name" class="block"></span>
		</div>
	</DialogShowcase>

	<div slot="details" class="flex-1 flex flex-col p-6 font-mono text-[11px]">
		<DialogInfoGrid
			id="dialog-info-grid"
			items={[
				{ label: "Name", value: "", dataAttr: "name" },
				{ label: "Family", value: "", dataAttr: "family" },
				{ label: "Period", value: "", dataAttr: "period" },
			]}
		/>

		<hr class="my-4 w-full border-t-px border-dotted text-muted" />

		<div class="mb-4">
			<div class="text-muted/50 uppercase tracking-wider text-[9px] mb-2">
				Equation
			</div>
			<div id="dialog-equation" class="text-primary font-mono text-sm"></div>
		</div>

		<hr class="my-4 w-full border-t-px border-dotted text-muted" />

		<div class="mb-4">
			<div class="flex items-center justify-between mb-2">
				<span class="text-muted/50 uppercase tracking-wider text-[9px]"
					>Code</span
				>
				<button
					id="dialog-copy-btn"
					class="font-ui text-[9px] tracking-widest uppercase text-muted hover:text-foreground transition-colors cursor-pointer"
				>
					Copy
				</button>
			</div>
			<div
				id="dialog-code-container"
				class="bg-surface border border-border rounded-md"
			>
				<!-- Code HTML injected here -->
			</div>
		</div>

		<div class="flex-1">
			<div class="text-muted/50 uppercase tracking-wider text-[9px] mb-2">
				Description
			</div>
			<div id="dialog-description" class="text-foreground/70 leading-relaxed">
			</div>
		</div>

		<div
			class="border-t border-border/60 pt-3 mt-3 flex items-center justify-between"
		>
			<span
				id="dialog-family"
				class="text-muted/50 uppercase tracking-widest text-[9px]"></span>
			<button
				id="dialog-close-btn"
				class="font-ui text-[9px] tracking-widest uppercase text-muted/50 hover:text-foreground transition-colors cursor-pointer"
			>
				Close
			</button>
		</div>
	</div>
</Dialog>

<script>
	import type { CurveName } from "@sarmal/core";
	import { createSarmal, curves } from "@sarmal/core";

	interface CurveMetadata {
		name: string;
		family: string;
		period: string;
		equation: string;
		description: string;
		color: string;
	}

	const sarmalCache = new Map<string, ReturnType<typeof createSarmal>>();

	const dialog = document.getElementById(
		"unified-curve-dialog",
	) as HTMLDialogElement;
	const canvas = document.getElementById(
		"unified-curve-canvas",
	) as HTMLCanvasElement;
	const curveNameEl = document.getElementById(
		"dialog-curve-name",
	) as HTMLSpanElement;
	const equationEl = document.getElementById(
		"dialog-equation",
	) as HTMLDivElement;
	const codeContainerEl = document.getElementById(
		"dialog-code-container",
	) as HTMLDivElement;
	const descriptionEl = document.getElementById(
		"dialog-description",
	) as HTMLDivElement;
	const familyEl = document.getElementById("dialog-family") as HTMLSpanElement;
	const copyBtn = document.getElementById(
		"dialog-copy-btn",
	) as HTMLButtonElement;
	const closeBtn = document.getElementById(
		"dialog-close-btn",
	) as HTMLButtonElement;
	const infoGridEl = document.getElementById("dialog-info-grid") as HTMLElement;

	let currentCurveId: string | null = null;
	let currentCodeText: string = "";

	function populateDialog(metadata: CurveMetadata, codeHtml: string) {
		curveNameEl.textContent = metadata.name;
		equationEl.textContent = metadata.equation;
		codeContainerEl.innerHTML = codeHtml;
		descriptionEl.textContent = metadata.description;
		familyEl.textContent = metadata.family;

		const gridItems = infoGridEl.querySelectorAll("[data-info-value]");
		gridItems.forEach((el) => {
			const key = el.getAttribute("data-info-value") as keyof CurveMetadata;
			if (key && metadata[key]) {
				el.textContent = String(metadata[key]);
			}
		});
	}

	function getOrCreateSarmal(
		curveId: string,
		color: string,
	): ReturnType<typeof createSarmal> {
		if (!sarmalCache.has(curveId)) {
			const curve = curves[curveId as CurveName];
			const foreground = getComputedStyle(document.documentElement)
				.getPropertyValue("--color-foreground")
				.trim();
			const sarmal = createSarmal(canvas, curve, {
				trailColor: color,
				skeletonColor: foreground,
				headColor: color,
				trailLength: 60,
			});
			sarmalCache.set(curveId, sarmal);
		}
		return sarmalCache.get(curveId)!;
	}

	// ! deferred to avoid competing with critical rendering
	function setupModalListeners() {
		document
			.querySelectorAll<HTMLButtonElement>("[data-curve-trigger]")
			.forEach((btn) => {
				btn.addEventListener("click", () => {
					const curveId = btn.dataset.curveId!;
					const codeText = btn.dataset.codeText!;
					const codeHtml = btn.dataset.codeHtml!;
					const metadata: CurveMetadata = JSON.parse(btn.dataset.metadataJson!);

					currentCurveId = curveId;
					currentCodeText = codeText;

					populateDialog(metadata, codeHtml);
					dialog.showModal();

					const sarmal = getOrCreateSarmal(curveId, metadata.color);
					sarmal.reset();
					sarmal.play();
				});
			});
	}

	// ! modal clicks aren't urgent on load
	if ("requestIdleCallback" in window) {
		requestIdleCallback(setupModalListeners, { timeout: 2000 });
	} else {
		// Safari < 2024 fallback
		setTimeout(setupModalListeners, 200);
	}

	copyBtn.addEventListener("click", async () => {
		if (currentCodeText) {
			await navigator.clipboard.writeText(currentCodeText);
			copyBtn.textContent = "Copied!";
			setTimeout(() => {
				copyBtn.textContent = "Copy";
			}, 2000);
		}
	});

	closeBtn.addEventListener("click", () => {
		dialog.close();
		if (currentCurveId) {
			sarmalCache.get(currentCurveId)?.pause();
		}
	});

	dialog.addEventListener("click", (e) => {
		if (e.target === dialog) {
			dialog.close();
			if (currentCurveId) {
				sarmalCache.get(currentCurveId)?.pause();
			}
		}
	});
</script>
