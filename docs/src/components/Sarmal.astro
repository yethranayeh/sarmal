---
import type { SarmalOptions, TrailStyle, TrailColor, CurveName } from "@sarmal/core";

interface Props extends SarmalOptions {
	curve?: CurveName;
	width?: number;
	height?: number;
	trailStyle?: TrailStyle;
	lazy?: boolean;
}

const defaultTrailColor = "#1b1c1a";
const defaultTrailLength = 120;

const {
	curve = "artemis2",
	width = 400,
	height = 400,
	trailColor = defaultTrailColor,
	skeletonColor = defaultTrailColor,
	headColor,
	headRadius = 2.5,
	trailLength = defaultTrailLength,
	trailStyle,
	lazy = false
} = Astro.props;

const curveId = `sarmal-${Math.random().toString(36).slice(2, 8)}`;
const resolvedHeadColor = headColor ?? (Array.isArray(trailColor) ? trailColor[0] : trailColor);
const serializedTrailColor = Array.isArray(trailColor) ? JSON.stringify(trailColor) : trailColor;
---

<canvas
	id={curveId}
	width={width}
	height={height}
	data-sarmal={lazy ? undefined : curve}
	data-sarmal-lazy={lazy ? curve : undefined}
	data-skeleton-color={skeletonColor}
	data-trail-color={serializedTrailColor}
	data-head-color={resolvedHeadColor}
	data-head-radius={headRadius}
	data-trail-length={trailLength}
	data-trail-style={trailStyle}></canvas>

<script>
	import "@sarmal/core/auto";
</script>
