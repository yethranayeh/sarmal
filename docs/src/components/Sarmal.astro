---
import type { SarmalOptions, TrailStyle, PalettePreset } from "@sarmal/core";
import { curves } from "@sarmal/core";

interface Props extends SarmalOptions {
	curve?: keyof typeof curves;
	width?: number;
	height?: number;
	trailStyle?: TrailStyle;
	palette?: PalettePreset;
}

const defaultTrailColor = "#1b1c1a";
const defaultTrailLength = 120;

const {
	curve = "artemis2",
	width = 400,
	height = 400,
	trailColor = defaultTrailColor,
	skeletonColor = defaultTrailColor,
	headColor,
	headRadius = 2.5,
	trailLength = defaultTrailLength,
	trailStyle,
	palette
} = Astro.props;

const curveId = `sarmal-${Math.random().toString(36).slice(2, 8)}`;
const resolvedHeadColor = headColor ?? trailColor;
---

<canvas
	id={curveId}
	width={width}
	height={height}
	data-sarmal={curve}
	data-skeleton-color={skeletonColor}
	data-trail-color={trailColor}
	data-head-color={resolvedHeadColor}
	data-head-radius={headRadius}
	data-trail-length={trailLength}
	data-trail-style={trailStyle}
	data-palette={palette}></canvas>

<script>
	import "@sarmal/core/auto";
</script>
