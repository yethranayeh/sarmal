---
import SectionLabel from "./SectionLabel.astro";

interface Props {
	variant?: "info" | "tip" | "warning" | "error" | "success";
	label?: string;
}

const variantConfig: Record<string, { label: string; accent: string }> = {
	info: { label: "Info", accent: "#1d6fa4" },
	tip: { label: "Tip", accent: "#2d6a4f" },
	warning: { label: "Warning", accent: "#b45309" },
	error: { label: "Error", accent: "#ba1a1a" },
	success: { label: "Success", accent: "#2d6a4f" },
};

const { variant = "info", label } = Astro.props;
const config = variantConfig[variant] ?? variantConfig.info;
const resolvedLabel = label ?? config.label;
---

<div
	class='not-prose overflow-hidden rounded-sm bg-surface [&_span[style*="background-color"]]:bg-(--alert-accent)!'
	style={`border: 1px solid ${config.accent}; border-left: 3px solid ${config.accent}; --alert-accent: ${config.accent};`}
>
	<div class="border-b border-border-subtle px-2 md:px-4 py-2 md:py-2.5">
		<SectionLabel label={resolvedLabel} variant={variant} template="kanji" />
	</div>
	<div
		class="prose prose-sm px-2 md:px-4 py-2 md:py-3 *:first:mt-0 *:last:mb-0 max-w-none"
	>
		<slot />
	</div>
</div>
