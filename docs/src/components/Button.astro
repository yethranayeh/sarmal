---
interface Props {
	id?: string;
	type?: "button" | "submit" | "reset";
	class?: string;
	variant?: "primary" | "ghost";
	active?: boolean;
}

const { id, type = "button", class: className, variant = "primary", active = false, ...props } = Astro.props;
---

<button
	id={id}
	type={type}
	{...props}
	class:list={[
		"font-mono text-xs tracking-wider uppercase cursor-pointer transition-colors",
		variant === "primary" && "bg-primary text-primary-foreground px-4 py-2 rounded-sm hover:bg-accent",
		variant === "ghost" && active && "text-primary",
		variant === "ghost" && !active && "text-muted hover:text-foreground",
		className
	]}>
	<slot />
</button>
