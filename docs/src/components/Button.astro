---
interface Props {
	id?: string;
	type?: "button" | "submit" | "reset";
	class?: string;
	variant?: "primary" | "ghost" | "ghost-inverted";
	active?: boolean;
	hoverColor?: "foreground" | "error";
}

const {
	id,
	type = "button",
	class: className,
	variant = "primary",
	active = false,
	hoverColor = "foreground",
	...props
} = Astro.props;
---

<button
	id={id}
	type={type}
	{...props}
	class:list={[
		"font-ui text-xs tracking-wider uppercase cursor-pointer transition-colors inline-flex items-center gap-1.5",
		variant === "primary" &&
			"bg-primary text-primary-foreground px-4 py-2 rounded-sm hover:bg-accent",
		variant === "ghost" && active && "text-primary",
		variant === "ghost" &&
			!active &&
			hoverColor === "foreground" &&
			"text-muted hover:text-foreground",
		variant === "ghost" &&
			!active &&
			hoverColor === "error" &&
			"text-muted hover:text-error",
		variant === "ghost-inverted" && "text-white/50 hover:text-white",
		className,
	]}
>
	<slot name="icon" />
	<slot />
</button>
