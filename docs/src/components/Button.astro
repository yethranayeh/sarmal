---
interface Props {
	id?: string;
	type?: "button" | "submit" | "reset";
	class?: string;
	variant?: "primary" | "ghost";
}

const { id, type = "button", class: className, variant = "primary" } = Astro.props;
---

<button
	id={id}
	type={type}
	class:list={[
		"font-mono text-xs tracking-wider uppercase cursor-pointer transition-colors",
		variant === "primary" && "bg-primary text-primary-foreground px-4 py-2 rounded-sm hover:bg-accent",
		variant === "ghost" && "text-muted underline underline-offset-2 hover:text-foreground",
		className
	]}>
	<slot />
</button>
