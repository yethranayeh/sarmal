---
import Block from "./Block.astro";

interface Props {
	label: string;
	variant?: "default" | "info" | "tip" | "warning" | "error" | "success";
	template?: "solid" | "kanji";
}

const { label, variant = "default", template = "solid" } = Astro.props;
---

<div class='flex items-center gap-2'>
	<Block variant={variant} template={template} />
	<span class='font-mono text-[10px] tracking-widest uppercase text-muted'>{label}</span>
</div>
