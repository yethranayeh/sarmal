---
interface Props {
	href: string;
	class?: string;
	external?: boolean;
	variant?: "inline" | "label";
}

const { href, class: className, external, variant = "inline" } = Astro.props;
const target = external ? "_blank" : undefined;
const rel = external ? "noopener noreferrer" : undefined;
---

<a
	href={href}
	target={target}
	rel={rel}
	class:list={[
		"text-primary underline-offset-2 no-underline hover:underline hover:text-accent transition-colors decoration-wavy",
		variant === "label" && "font-mono text-xs tracking-wider uppercase",
		className,
	]}><slot /></a
>
