---
import katex from "katex";
import "katex/dist/katex.min.css";

interface Props {
	equation: string;
}

const { equation } = Astro.props;

const lines = equation.split("\\\\").map((l) => l.trim());

const latex =
	lines.length === 1
		? equation
		: `\\begin{aligned}${lines.map((l) => `${l} &`).join("\\\\")}\\end{aligned}`;

const html = katex.renderToString(latex, {
	displayMode: true,
	throwOnError: false,
});
---

<div
	class="overflow-x-auto py-4 bg-surface-raised rounded-lg"
	set:html={html}
/>
