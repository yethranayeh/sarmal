---
import type { CurveName } from "@sarmal/core";

import { curves } from "@sarmal/core";
import { Code } from "astro:components";

import Dialog from "./Dialog/Dialog.astro";
import DialogShowcase from "./Dialog/DialogShowcase.astro";
import DialogInfoGrid from "./Dialog/DialogInfoGrid.astro";
import CopyButton from "./CopyButton.astro";

import { codeThemes } from "../lib/shiki";

interface Props {
	fromId: CurveName;
	toId: CurveName;
}

const { fromId, toId } = Astro.props;
const fromCurve = curves[fromId as CurveName];
const toCurve = curves[toId as CurveName];

if (!fromCurve || !toCurve) {
	throw new Error(`Unknown curve pair: ${fromId} -> ${toId}`);
}

const morphSnippet = `sarmal.morphTo(curves.${toId});`;
---

<Dialog id={`morph-${fromId}-${toId}-modal`}>
	<DialogShowcase slot='showcase' canvasId={`morph-${fromId}-${toId}-modal-canvas`}>
		<div
			slot='top-left'
			class='absolute top-4 left-4 font-mono text-[9px] tracking-widest uppercase text-muted/60 leading-relaxed pointer-events-none'>
			<span class='block'>{fromCurve.name} → {toCurve.name}</span>
		</div>
	</DialogShowcase>

	<div slot='details' class='flex-1 flex flex-col p-6 font-mono text-[11px]'>
		<DialogInfoGrid
			items={[
				{ label: "From", value: fromCurve.name },
				{ label: "To", value: toCurve.name },
				{ label: "Type", value: "Morph" }
			]}
		/>

		<hr class='my-4 w-full border-t-px border-dotted text-muted' />

		<div class='mb-4'>
			<div class='flex items-center justify-between mb-2'>
				<span class='text-muted/50 uppercase tracking-wider text-[9px]'>Code</span>
				<CopyButton code={morphSnippet} variant='ghost' />
			</div>
			<div class='bg-surface border border-border rounded-md'>
				<Code
					class='p-2 rounded-md'
					lang='javascript'
					theme={undefined}
					themes={codeThemes}
					defaultColor={false}
					code={morphSnippet}
				/>
			</div>
		</div>

		<div class='flex-1'>
			<div class='text-muted/50 uppercase tracking-wider text-[9px] mb-2'>Description</div>
			<div class='text-foreground/70 leading-relaxed'>
				Watch the curve morph from <span class='text-primary'>{fromCurve.name}</span> to{" "}
				<span class='text-primary'>{toCurve.name}</span>. The animation smoothly interpolates between the two curve
				definitions.
			</div>
		</div>

		<div class='border-t border-border/60 pt-3 mt-3 flex items-center justify-between'>
			<span class='text-muted/50 uppercase tracking-widest text-[9px]'>Morph</span>
			<button
				data-morph-close-btn
				class='font-mono text-[9px] tracking-widest uppercase text-muted/50 hover:text-foreground transition-colors cursor-pointer'>
				Close
			</button>
		</div>
	</div>
</Dialog>

<script>
	import type { CurveName } from "@sarmal/core";
	import { createSarmal, curves } from "@sarmal/core";

	interface MorphModal {
		fromId: string;
		toId: string;
		dialog: HTMLDialogElement;
		canvas: HTMLCanvasElement;
		openBtn: HTMLButtonElement | null;
		closeBtn: HTMLButtonElement;
		sarmal: ReturnType<typeof createSarmal> | null;
		initialized: boolean;
	}

	const colorMap: Record<string, string> = {
		astroid: "#38bdf8",
		deltoid: "#fb923c",
		rose3: "#e879f9",
		epitrochoid7: "#a78bfa",
		lissajous32: "#fb923c",
		rose5: "#f472b6",
		lame: "#a78bfa"
	};

	const MORPH_DURATION = 800;

	async function initMorphModal(modal: MorphModal) {
		const { fromId, toId, dialog, canvas, closeBtn } = modal;

		modal.openBtn?.addEventListener("click", async () => {
			dialog.showModal();

			if (!modal.initialized) {
				const fromCurve = curves[fromId as CurveName];
				modal.sarmal = createSarmal(canvas, fromCurve, {
					trailColor: colorMap[fromId] || "#60a5fa",
					skeletonColor: colorMap[fromId] || "#60a5fa",
					headColor: colorMap[fromId] || "#60a5fa",
					trailLength: 60
				});
				modal.initialized = true;
			}

			modal.sarmal!.reset();
			modal.sarmal!.play();

			const HOLD_DURATION = 2400;

			async function runMorphLoop() {
				while (dialog.open) {
					await modal.sarmal!.morphTo(curves[toId as CurveName], { duration: MORPH_DURATION });
					await new Promise((resolve) => setTimeout(resolve, HOLD_DURATION));
					await modal.sarmal!.morphTo(curves[fromId as CurveName], { duration: MORPH_DURATION });
					await new Promise((resolve) => setTimeout(resolve, HOLD_DURATION));
				}
			}

			runMorphLoop();
		});

		closeBtn.addEventListener("click", () => {
			dialog.close();
			modal.sarmal?.pause();
		});

		dialog.addEventListener("click", (e) => {
			if (e.target === dialog) {
				dialog.close();
				modal.sarmal?.pause();
			}
		});
	}

	document.querySelectorAll<HTMLDialogElement>("[id^='morph-'][id$='-modal']").forEach((dialog) => {
		const idMatch = dialog.id.match(/^morph-(.+)-(.+)-modal$/);
		if (!idMatch) return;

		const fromId = idMatch[1]!;
		const toId = idMatch[2]!;
		const canvas = document.getElementById(`morph-${fromId}-${toId}-modal-canvas`) as HTMLCanvasElement;
		const openBtn = document.getElementById(`morph-${fromId}-${toId}-details`) as HTMLButtonElement | null;
		const closeBtn = dialog.querySelector("[data-morph-close-btn]") as HTMLButtonElement;

		initMorphModal({
			fromId,
			toId,
			dialog,
			canvas,
			openBtn,
			closeBtn,
			sarmal: null,
			initialized: false
		});
	});
</script>
