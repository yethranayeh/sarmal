---
import type { MarkdownLayoutProps } from "astro";

import { Menu, X, BookText, FlaskConical } from "@lucide/astro";

import BaseLayout from "./BaseLayout.astro";
import Branding from "../components/Branding.astro";
import Nav from "../components/Nav.astro";

interface DocFrontmatter {
	title: string;
	description: string;
	sidebarLabel: string;
	order: number;
}

interface DocModule {
	frontmatter: DocFrontmatter;
}

interface NavItem {
	href: string;
	label: string;
	order: number;
}

type Props = Partial<MarkdownLayoutProps<DocFrontmatter>> & {
	title?: string;
	description?: string;
};

const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? Astro.props.title ?? "";
const description = frontmatter?.description ?? Astro.props.description ?? "";
const currentPath = Astro.url.pathname;

const docModules = import.meta.glob<DocModule>("../pages/docs/*.mdx", { eager: true });

const navItems: NavItem[] = [
	{ href: "/docs", label: "Introduction", order: -1 },
	...Object.entries(docModules)
		.map(([path, mod]) => {
			const slug = path.replace("../pages/docs/", "").replace(".mdx", "");
			return {
				href: `/docs/${slug}`,
				label: mod.frontmatter.sidebarLabel,
				order: mod.frontmatter.order
			};
		})
		.sort((a, b) => a.order - b.order)
		.slice(0, 5)
];

const isActive = (href: string) => {
	if (href === "/docs") {
		return currentPath === "/docs" || currentPath === "/docs/";
	}
	return currentPath.startsWith(href);
};

// TODO: should docsLayout override the navbar slot?
// FIXME: will go stale if main Nav changes...
const topNavLinks = [
	{ href: "/docs", label: "Docs", icon: BookText },
	{ href: "/play", label: "Playground", icon: FlaskConical }
];
---

<BaseLayout title={title} description={description}>
	<header
		slot='navbar'
		class='bg-surface-raised w-full px-4 py-2 flex items-center justify-between border-b border-border'>
		<Branding />

		<div class='flex items-center gap-4'>
			<!-- Desktop nav links -->
			<Nav />

			<!-- Mobile hamburger -->
			<button
				id='mobile-menu-btn'
				class='lg:hidden flex items-center justify-center w-9 h-9 rounded-md hover:bg-surface transition-colors'
				aria-label='Open navigation menu'
				aria-expanded='false'
				aria-controls='mobile-drawer'>
				<Menu size={20} />
			</button>
		</div>
	</header>

	<div class='flex flex-1'>
		<!-- Desktop sidebar -->
		<aside
			class='hidden lg:block sticky top-0 w-64 shrink-0 h-screen bg-surface border-r border-border'
			aria-label='Documentation navigation'>
			<nav class='p-4' aria-label='Documentation sections'>
				<ul class='space-y-1' role='list'>
					{
						navItems.map((item) => {
							const active = isActive(item.href);
							return (
								<li>
									<a
										href={item.href}
										class:list={[
											'block px-3 py-2 text-sm rounded-md duration-300 transition-all [font-variation-settings:"wght"_var(--wght)]',
											{
												"text-primary border-l-2 border-primary bg-surface-raised font-medium [--wght:650]": active,
												"text-muted hover:text-foreground hover:bg-surface-raised border-l-2 border-transparent [--wght:350] hover:[--wght:650]":
													!active
											}
										]}
										aria-current={active ? "page" : undefined}>
										{item.label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</aside>

		<!-- Mobile drawer (slides in from the right) -->
		<div
			id='mobile-drawer'
			class='lg:hidden fixed inset-y-0 right-0 z-50 w-72 bg-surface border-l border-border transform translate-x-full transition-transform duration-200 ease-out flex flex-col'
			aria-label='Navigation menu'>
			<!-- Drawer header -->
			<div class='flex items-center justify-between px-4 py-2 border-b border-border shrink-0 bg-surface-raised'>
				<h2>Menu</h2>
				<button
					id='mobile-menu-close'
					class='flex items-center justify-center w-9 h-9 rounded-md hover:bg-surface transition-colors'
					aria-label='Close navigation menu'>
					<X size={20} />
				</button>
			</div>

			<!-- Top nav links -->
			<div class='px-4 py-3 border-b border-border shrink-0'>
				<nav class='flex flex-col gap-1'>
					{
						topNavLinks.map((link) => {
							const isLinkActive =
								link.href === "/docs" ? currentPath.startsWith("/docs") : currentPath.startsWith(link.href);
							const Icon = link.icon;
							return (
								<a
									href={link.href}
									class:list={[
										"inline-flex items-center gap-2 px-3 py-2 rounded-md font-mono text-xs tracking-wider uppercase transition-colors hover:bg-surface-raised hover:text-foreground",
										isLinkActive ? "text-primary" : "text-muted"
									]}>
									<Icon size={16} />
									<span>{link.label}</span>
								</a>
							);
						})
					}
				</nav>
			</div>

			<!-- Sidebar doc links -->
			<nav class='flex-1 overflow-y-auto p-4' aria-label='Documentation sections'>
				<p class='px-3 pb-2 text-xs font-mono tracking-widest uppercase text-muted'>Documentation</p>
				<ul class='space-y-1' role='list'>
					{
						navItems.map((item) => {
							const active = isActive(item.href);
							return (
								<li>
									<a
										href={item.href}
										class:list={[
											'block px-3 py-2 text-sm rounded-md duration-300 transition-all [font-variation-settings:"wght"_var(--wght)]',
											{
												"text-primary border-l-2 border-primary bg-surface-raised font-medium [--wght:650]": active,
												"text-muted hover:text-foreground hover:bg-surface-raised border-l-2 border-transparent [--wght:350] hover:[--wght:650]":
													!active
											}
										]}
										aria-current={active ? "page" : undefined}>
										{item.label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</div>

		<!-- Overlay -->
		<div id='sidebar-overlay' class='fixed inset-0 bg-black/60 z-40 hidden lg:hidden' aria-hidden='true'></div>

		<main class='flex-1 min-w-0 p-4 md:p-8'>
			<slot name='article-header' />
			<article class='prose max-w-3xl mx-auto lg:mx-0 prose-headings:font-medium'>
				<slot />
			</article>
		</main>
	</div>
</BaseLayout>

<script>
	const menuBtn = document.getElementById("mobile-menu-btn");
	const closeBtn = document.getElementById("mobile-menu-close");
	const drawer = document.getElementById("mobile-drawer");
	const overlay = document.getElementById("sidebar-overlay");

	function openMenu() {
		drawer?.classList.remove("translate-x-full");
		overlay?.classList.remove("hidden");
		menuBtn?.setAttribute("aria-expanded", "true");
		document.body.style.overflow = "hidden";
	}

	function closeMenu() {
		drawer?.classList.add("translate-x-full");
		overlay?.classList.add("hidden");
		menuBtn?.setAttribute("aria-expanded", "false");
		document.body.style.overflow = "";
	}

	menuBtn?.addEventListener("click", openMenu);
	closeBtn?.addEventListener("click", closeMenu);
	overlay?.addEventListener("click", closeMenu);

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeMenu();
	});

	drawer?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", closeMenu);
	});
</script>
