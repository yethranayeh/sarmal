---
import { ChevronsLeft } from "@lucide/astro";
import { palettes } from "@sarmal/core";

import BaseLayout from "../layouts/BaseLayout.astro";
import Sarmal from "../components/Sarmal.astro";
import Link from "../components/Link.astro";

import { SEPARATOR_DOT } from "../variables";
---

<BaseLayout title={`Not Found ${SEPARATOR_DOT} Sarmal`} description="This path doesn't exist.">
	<main class='flex-1 flex flex-col items-center justify-center px-6 py-16'>
		<div class='flex flex-col items-center max-w-xs w-full'>
			<div class='relative w-70 h-70 enter-anim' style='--enter-delay: 0ms'>
				<div class='absolute scale-101 blur-[1px]'>
					<Sarmal
						curve='rose5'
						width={280}
						height={280}
						trailColor={palettes.fire}
						skeletonColor={palettes.fire[0]}
						trailLength={200}
						speed={-0.3}
					/>
				</div>
				<Sarmal
					curve='rose5'
					width={280}
					height={280}
					trailColor={palettes.fire}
					skeletonColor={palettes.fire[0]}
					trailLength={200}
					speed={0.3}
				/>
			</div>

			<p
				class='inline-block mt-6 font-mono text-lg tracking-[0.3em] uppercase text-primary label-404 enter-anim'
				style='--enter-delay: 120ms'>
				404
			</p>

			<h1 class='mt-2 text-2xl font-normal text-foreground text-center enter-anim' style='--enter-delay: 240ms'>
				This path doesn't <span class='text-primary'>exist</span>.
			</h1>

			<div class='enter-anim' style='--enter-delay: 360ms'>
				<!-- TODO: merge into a reusable component. Duplicated in curve detail page -->
				<Link href='/' class='group inline-flex items-center'>
					<ChevronsLeft
						size={24}
						class='opacity-75 [&>path:nth-child(1)]:transition-transform [&>path:nth-child(1)]:translate-x-1.75 group-hover:opacity-100 group-hover:-translate-x-2 group-hover:[&>path:nth-child(1)]:translate-x-0 transition-all'
					/>
					Back Home</Link
				>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	/* Partial keyframe — inherits current state as `to`, so no layout jump */
	@keyframes enter {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
	}

	@keyframes breathe {
		0%,
		100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.015);
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		.enter-anim {
			animation: enter 600ms cubic-bezier(0.16, 1, 0.3, 1) var(--enter-delay, 0ms) both;
		}

		.label-404 {
			animation:
				enter 600ms cubic-bezier(0.16, 1, 0.3, 1) 120ms both,
				breathe 800ms ease-in-out 900ms 1 both;
		}
	}
</style>
