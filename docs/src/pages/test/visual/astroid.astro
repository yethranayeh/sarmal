---
// Visual regression test fixture: Astroid canvas at seek(π)
// Minimal page with no chrome for deterministic pixel comparison
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Test — Astroid Canvas</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: #0e0e0e;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
      #canvas-container {
        width: 200px;
        height: 200px;
      }
      canvas {
        display: block;
        width: 200px;
        height: 200px;
      }
    </style>
  </head>
  <body>
    <div id="canvas-container">
      <canvas id="astroid-canvas" width="200" height="200"></canvas>
    </div>

    <script>
      import { createSarmal, curves } from '@sarmal/core';

      const canvas = document.getElementById('astroid-canvas') as HTMLCanvasElement;
      const sarmal = createSarmal(canvas, curves.astroid, {
        trailColor: '#ffffff',
        skeletonColor: '#888888',
        headColor: '#ffffff',
        headRadius: 4,
        trailLength: 120,
      });

      // Deterministic setup: seek to fixed position and stop
      sarmal.start();
      sarmal.seek(Math.PI);
      requestAnimationFrame(() => sarmal.stop());
    </script>
  </body>
</html>
