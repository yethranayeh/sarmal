---
// Visual regression test fixture: Mid-morph frame (Astroid → Deltoid at alpha=0.5)
// Minimal page with no chrome for deterministic pixel comparison
// Uses low-level API to set exact morph alpha
//
// NOTE: This page is built in production but only used for visual testing.
// It was originally marked prerender=false to "exclude from production" but that
// doesn't work in Astro without a server adapter. Keeping it as a static page
// is harmless and simpler.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Test — Morph Mid</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: #0e0e0e;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
      #canvas-container {
        width: 200px;
        height: 200px;
      }
      canvas {
        display: block;
        width: 200px;
        height: 200px;
      }
    </style>
  </head>
  <body>
    <div id="canvas-container">
      <canvas id="morph-canvas" width="200" height="200"></canvas>
    </div>

    <script>
      import { createEngine, createRenderer, curves } from '@sarmal/core';

      const canvas = document.getElementById('morph-canvas') as HTMLCanvasElement;

      // Create engine directly to access setMorphAlpha
      const engine = createEngine(curves.astroid);

      // Start morph to deltoid
      engine.startMorph(curves.deltoid, 'normalized');

      // Set exact mid-morph alpha
      engine.setMorphAlpha(0.5);

      // Create renderer and render single frame (autoStart: false prevents RAF loop)
      createRenderer({
        canvas,
        engine,
        autoStart: false,
        initialT: Math.PI,
        trailColor: '#ffffff',
        skeletonColor: '#888888',
        headColor: '#ffffff',
        headRadius: 4,
      });
      // No play(), no RAF, no pause needed — one deterministic frame already drawn
    </script>
  </body>
</html>
