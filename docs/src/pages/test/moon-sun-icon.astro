---
import "../../styles/globals.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Moon → Sun Icon</title>
		<style is:global>
			:root {
				--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
				--spring: linear(
					0,
					0.008,
					0.068,
					0.209,
					0.394,
					0.591,
					0.769,
					0.905,
					0.987,
					1.011,
					1.001,
					0.987,
					0.984,
					0.997,
					1.005,
					1.002,
					0.999,
					0.999,
					1
				);
			}

			body {
				margin: 0;
				padding: 2rem;
				background: var(--color-background, #fbf9f5);
				color: var(--color-foreground, #1b1c1a);
				font-family: system-ui, sans-serif;
			}

			h1 {
				font-family: "Newsreader", Georgia, serif;
				font-size: 1.25rem;
				margin: 0 0 0.2rem;
			}

			.subtitle {
				color: #7a7067;
				font-size: 0.75rem;
				margin: 0 0 2.5rem;
			}

			.row {
				display: flex;
				align-items: flex-start;
				gap: 2rem;
				margin-bottom: 2.5rem;
			}

			.card {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}

			.card-label {
				font-size: 0.7rem;
				font-weight: 600;
				color: #7a7067;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.stage {
				width: 96px;
				height: 96px;
				border-radius: 12px;
				border: 1px solid #e4e2de;
				background: #f0efe8;
				color: #1b1c1a;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}

			.stage.dark {
				background: #1b1c1a;
				border-color: #2e2e2e;
				color: #fbf9f5;
			}

			.stage svg {
				display: block;
				overflow: visible;
			}

			/* Phase 1: path d morphs crescent → r=9 full circle.
			   Inner arc expands outward (r=6→9), bite fills in.
			   Phase 2: only the circle path scales to 0.45×
			   (r=9 → r≈4). Rays are siblings and stay full scale,
			   so they land at their r=8–10 Lucide positions.
			   vector-effect keeps stroke at 2px when scaled. */

			.icon-body {
				vector-effect: non-scaling-stroke;
				transform-box: view-box;
				transform-origin: 50% 50%;
				/* leave: un-scale first, then morph back */
				transition:
					transform 0.35s var(--ease-out-expo) 0s,
					d 0.5s var(--ease-out-expo) 0.2s;
			}

			.stage:hover .icon-body,
			.real-stage:hover .icon-body {
				d: path("M21 12a9 9 0 1 1-9-9c0 0 0 0 0 0a9 9 0 0 1 9 9c0 0 0 0 0 0");
				transform: scale(0.45);
				/* enter: morph first, then scale */
				transition:
					d 0.5s var(--ease-out-expo) 0s,
					transform 0.4s var(--ease-out-expo) 0.35s;
			}

			/* Rays */
			.icon-rays {
				opacity: 0;
				transform: rotate(-30deg) scale(0.5);
				transform-box: view-box;
				transform-origin: 50% 50%;
				transition:
					opacity 0.15s ease 0s,
					transform 0.2s ease 0s;
			}

			.stage:hover .icon-rays,
			.real-stage:hover .icon-rays {
				opacity: 1;
				transform: none;
				transition:
					opacity 0.3s ease 0.6s,
					transform 0.55s var(--spring) 0.55s;
			}

			/* ── Real scale ─────────────────────────────── */

			.divider {
				border: none;
				border-top: 1px solid #e4e2de;
				margin: 0.5rem 0 2rem;
			}

			h2 {
				font-family: "Newsreader", Georgia, serif;
				font-size: 0.9rem;
				font-weight: 400;
				margin: 0 0 1rem;
				color: #7a7067;
			}

			.real-stage {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				border-radius: 6px;
				border: 1px solid #e4e2de;
				background: #f0efe8;
				color: #1b1c1a;
				cursor: pointer;
			}

			.real-stage.dark {
				background: #1b1c1a;
				border-color: #2e2e2e;
				color: #fbf9f5;
			}

			.real-stage svg {
				display: block;
				overflow: visible;
			}
		</style>
	</head>
	<body>
		<h1>Moon → Sun</h1>
		<p class="subtitle">
			Path morph via CSS <code>d</code> property. Hover to trigger.
		</p>

		<div class="row">
			<div class="card">
				<div class="card-label">Light</div>
				<div class="stage">
					<svg
						class="icon-svg"
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							class="icon-body"
							d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
						></path>
						<g class="icon-rays">
							<path d="M12 2v2"></path>
							<path d="M12 20v2"></path>
							<path d="m4.93 4.93 1.41 1.41"></path>
							<path d="m17.66 17.66 1.41 1.41"></path>
							<path d="M2 12h2"></path>
							<path d="M20 12h2"></path>
							<path d="m6.34 17.66-1.41 1.41"></path>
							<path d="m19.07 4.93-1.41 1.41"></path>
						</g>
					</svg>
				</div>
			</div>

			<div class="card">
				<div class="card-label">Dark</div>
				<div class="stage dark">
					<svg
						class="icon-svg"
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							class="icon-body"
							d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
						></path>
						<g class="icon-rays">
							<path d="M12 2v2"></path>
							<path d="M12 20v2"></path>
							<path d="m4.93 4.93 1.41 1.41"></path>
							<path d="m17.66 17.66 1.41 1.41"></path>
							<path d="M2 12h2"></path>
							<path d="M20 12h2"></path>
							<path d="m6.34 17.66-1.41 1.41"></path>
							<path d="m19.07 4.93-1.41 1.41"></path>
						</g>
					</svg>
				</div>
			</div>
		</div>

		<hr class="divider" />
		<h2>Hovered state (static, for iteration)</h2>
		<div class="row">
			<div class="card">
				<div class="card-label">Current (sweep=0)</div>
				<div class="stage" style="pointer-events:none">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							style="d:path('M21 12a9 9 0 1 1-9-9c0 0 0 0 0 0a9 9 0 0 0 9 9c0 0 0 0 0 0');transform:scale(0.45);transform-box:view-box;transform-origin:50% 50%;vector-effect:non-scaling-stroke"
						></path>
						<g
							style="opacity:1;transform:none;transform-box:view-box;transform-origin:50% 50%"
						>
							<path d="M12 2v2"></path><path d="M12 20v2"></path>
							<path d="m4.93 4.93 1.41 1.41"></path><path
								d="m17.66 17.66 1.41 1.41"></path>
							<path d="M2 12h2"></path><path d="M20 12h2"></path>
							<path d="m6.34 17.66-1.41 1.41"></path><path
								d="m19.07 4.93-1.41 1.41"></path>
						</g>
					</svg>
				</div>
			</div>
			<div class="card">
				<div class="card-label">Fixed (sweep=1)</div>
				<div class="stage" style="pointer-events:none">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							style="d:path('M21 12a9 9 0 1 1-9-9c0 0 0 0 0 0a9 9 0 0 1 9 9c0 0 0 0 0 0');transform:scale(0.45);transform-box:view-box;transform-origin:50% 50%;vector-effect:non-scaling-stroke"
						></path>
						<g
							style="opacity:1;transform:none;transform-box:view-box;transform-origin:50% 50%"
						>
							<path d="M12 2v2"></path><path d="M12 20v2"></path>
							<path d="m4.93 4.93 1.41 1.41"></path><path
								d="m17.66 17.66 1.41 1.41"></path>
							<path d="M2 12h2"></path><path d="M20 12h2"></path>
							<path d="m6.34 17.66-1.41 1.41"></path><path
								d="m19.07 4.93-1.41 1.41"></path>
						</g>
					</svg>
				</div>
			</div>
		</div>

		<hr class="divider" />
		<h2>Real scale (16 px)</h2>
		<div class="row">
			<div class="real-stage">
				<svg
					class="icon-svg"
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path
						class="icon-body"
						d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
					></path>
					<g class="icon-rays">
						<path d="M12 2v2"></path>
						<path d="M12 20v2"></path>
						<path d="m4.93 4.93 1.41 1.41"></path>
						<path d="m17.66 17.66 1.41 1.41"></path>
						<path d="M2 12h2"></path>
						<path d="M20 12h2"></path>
						<path d="m6.34 17.66-1.41 1.41"></path>
						<path d="m19.07 4.93-1.41 1.41"></path>
					</g>
				</svg>
			</div>

			<div class="real-stage dark">
				<svg
					class="icon-svg"
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path
						class="icon-body"
						d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
					></path>
					<g class="icon-rays">
						<path d="M12 2v2"></path>
						<path d="M12 20v2"></path>
						<path d="m4.93 4.93 1.41 1.41"></path>
						<path d="m17.66 17.66 1.41 1.41"></path>
						<path d="M2 12h2"></path>
						<path d="M20 12h2"></path>
						<path d="m6.34 17.66-1.41 1.41"></path>
						<path d="m19.07 4.93-1.41 1.41"></path>
					</g>
				</svg>
			</div>
		</div>
	</body>
</html>
