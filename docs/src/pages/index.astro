---
import "../styles/globals.css";
import { Code } from "astro:components";

import Sarmal from "../components/Sarmal.astro";
import Button from "../components/Button.astro";
import Artemis2Modal from "../components/Artemis2Modal.astro";
import SectionLabel from "../components/SectionLabel.astro";
import { SEPARATOR_DOT } from "../variables";

const sarmals = [
	{ id: "rose3", name: "Rose (n=3)", color: "#e879f9" },
	{ id: "deltoid", name: "Deltoid", color: "#fb923c" },
	{ id: "astroid", name: "Astroid", color: "#38bdf8" },
	{ id: "epitrochoid7", name: "Epitrochoid", color: "#a78bfa" },
	{ id: "rose5", name: "Rose (n=5)", color: "#f472b6" }
] as const;
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='icon' href='/favicon.ico' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />

		<title>Sarmal</title>
		<meta
			name='description'
			content='Beautiful loading spinners from two lines of math. 2.86 KB, zero dependencies. Drop in a canvas, pick a curve.'
		/>

		<meta property='og:type' content='website' />
		<meta property='og:url' content='https://sarmal.art/' />
		<meta property='og:title' content='Sarmal | Loading indicators from parametric curves' />
		<meta
			property='og:description'
			content='Beautiful loading spinners from two lines of math. 2.86 KB, zero dependencies. Drop in a canvas, pick a curve.'
		/>
		<meta property='og:image' content='https://sarmal.art/og-image.png' />
		<meta property='og:image:width' content='1200' />
		<meta property='og:image:height' content='630' />
		<meta property='og:image:alt' content='Sarmal - A loading spinner tracing the Artemis II trajectory' />
		<meta property='og:site_name' content='Sarmal' />

		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content='Sarmal | Loading indicators from parametric curves' />
		<meta
			name='twitter:description'
			content='Beautiful loading spinners from two lines of math. 2.86 KB, zero dependencies.'
		/>
		<meta name='twitter:image' content='https://sarmal.art/og-image.png' />
		<meta name='twitter:image:alt' content='Sarmal - A loading spinner tracing the Artemis II trajectory' />

		<link rel='canonical' href='https://sarmal.art/' />
	</head>
	<body class='min-h-screen'>
		<header class='w-full px-4 py-3 flex items-center justify-between border-b border-border'>
			<a href='/' class='font-heading text-lg text-foreground hover:text-primary transition-colors'>
				<span class='text-primary'>sarmal</span>.art
			</a>
			<div class='flex items-center gap-4'>
				<a
					href='/play'
					class='font-mono text-xs tracking-wider uppercase text-muted hover:text-foreground transition-colors'>
					Play
				</a>
				<a
					href='https://github.com/yethranayeh/sarmal'
					target='_blank'
					rel='noopener noreferrer'
					class='font-mono text-xs tracking-wider uppercase text-muted hover:text-foreground transition-colors'>
					GitHub
				</a>
			</div>
		</header>
	</body>

	<main class='max-w-3xl mx-auto p-4'>
		<section class='text-center mb-16'>
			<div class='flex flex-col items-center mb-6 gap-2'>
				<canvas id='artemis2-hero' width={200} height={130}></canvas>
				<div class='flex items-center gap-3'>
					<span id='artemis2-status' class='font-mono text-[10px] tracking-wider uppercase text-muted'></span>{
						` ${SEPARATOR_DOT}`
					}<span class='text-primary text-[12px]'>Integrity</span>{` ${SEPARATOR_DOT}`}
					<Button id='artemis2-details' variant='ghost'>Details</Button>
				</div>
			</div>
			<h1 class='font-heading italic text-4xl md:text-5xl leading-tight tracking-tight text-foreground mb-3'>
				Loading <span class='text-primary'>Artemis II</span>
			</h1>
			<p class='font-body text-base text-muted max-w-sm mx-auto mb-8'>
				A spinner tracing humanity's return to <span class='text-primary'>the Moon</span>. <em>The first</em> crewed lunar
				flight since <span class='text-primary'>Apollo 17</span>.
			</p>

			<div class='flex flex-col justify-start max-w-md mx-auto'>
				<div class='flex justify-start mb-3'>
					<SectionLabel label='Two lines of HTML' />
				</div>
				<div class='bg-surface border border-border rounded-md text-left'>
					<Code
						class='p-2'
						code={`<script src="https://unpkg.com/@sarmal/core/dist/auto-init.js"></script>
<canvas
  data-sarmal="artemis2"
  data-trail-color="#60a5fa"
  data-skeleton-color="#60a5fa"></canvas>`}
						lang='html'
						theme='horizon-bright'
					/>
				</div>
			</div>
		</section>

		<section>
			<h2 class='font-heading text-xl text-center text-foreground mb-6'>Standard sarmals</h2>
			<div class='grid grid-cols-3 md:grid-cols-5 gap-4'>
				{
					sarmals.map((curve) => (
						<div class='flex flex-col items-center'>
							<div title={curve.id} class='bg-surface border border-border rounded-md p-3 mb-2 overflow-visible'>
								<Sarmal curve={curve.id} width={72} height={72} trailColor={curve.color} />
							</div>
							<span title={curve.id} class='font-mono text-[10px] tracking-wider uppercase text-muted'>
								{curve.name}
							</span>
						</div>
					))
				}
			</div>
		</section>
	</main>

	<footer class='w-full px-4 py-6 border-t border-border text-center'>
		<p class='font-mono text-[10px] tracking-wider text-muted'>
			0.0000028 GB gzipped {SEPARATOR_DOT} MIT License {SEPARATOR_DOT} © 2026
		</p>
	</footer>
	<Artemis2Modal />

	<script>
		import { createSarmal, curves } from "@sarmal/core";

		const LAUNCH = new Date("2026-04-01T22:35:12Z").getTime();
		const SPLASHDOWN = new Date("2026-04-11T00:21:00Z").getTime();
		const TOTAL_HOURS = (SPLASHDOWN - LAUNCH) / (1000 * 60 * 60);
		const TWO_PI = Math.PI * 2;
		const SPEED = curves.artemis2.speed ?? 1;
		const LIVE_T = 2.27;

		const canvas = document.getElementById("artemis2-hero") as HTMLCanvasElement;
		const statusEl = document.getElementById("artemis2-status") as HTMLElement;

		const sarmal = createSarmal(canvas, curves.artemis2, {
			trailColor: "#60a5fa",
			skeletonColor: "#1b1c1a",
			headColor: "#60a5fa",
			trailLength: 300,
			glowSize: 0
		});

		const elapsedHours = (LIVE_T / TWO_PI) * TOTAL_HOURS;
		const dayNumber = Math.floor(elapsedHours / 24) + 1;

		statusEl.textContent = `Day ${dayNumber}`;

		const SEEK_MS = (LIVE_T / SPEED) * 1000;

		sarmal.start();
		setTimeout(() => {
			sarmal.seek(LIVE_T);
			requestAnimationFrame(() => sarmal.stop());
		}, SEEK_MS);
	</script>
</html>
