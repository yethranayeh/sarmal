---
import "../styles/globals.css";
import Sarmal from "../components/Sarmal.astro";
import SectionLabel from "../components/SectionLabel.astro";
import { Code } from "astro:components";

const sarmals = [
	{ id: "rose3", name: "Rose (n=3)", color: "#e879f9" },
	{ id: "deltoid", name: "Deltoid", color: "#fb923c" },
	{ id: "astroid", name: "Astroid", color: "#38bdf8" },
	{ id: "epitrochoid7", name: "Epitrochoid", color: "#a78bfa" },
	{ id: "rose5", name: "Rose (n=5)", color: "#f472b6" }
] as const;
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='icon' href='/favicon.ico' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />

		<title>Sarmal</title>
		<meta
			name='description'
			content='Beautiful loading spinners from two lines of math. 2.8 KB, zero dependencies. Drop in a canvas, pick a curve.'
		/>

		<meta property='og:type' content='website' />
		<meta property='og:url' content='https://sarmal.art/' />
		<meta property='og:title' content='Sarmal | Loading indicators from parametric curves' />
		<meta
			property='og:description'
			content='Beautiful loading spinners from two lines of math. 2.75 KB, zero dependencies. Drop in a canvas, pick a curve.'
		/>
		<meta property='og:image' content='https://sarmal.art/og-image.png' />
		<meta property='og:image:width' content='1200' />
		<meta property='og:image:height' content='630' />

		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content='Sarmal | Loading indicators from parametric curves' />
		<meta
			name='twitter:description'
			content='Beautiful loading spinners from two lines of math. 2.75 KB, zero dependencies.'
		/>
		<meta name='twitter:image' content='https://sarmal.art/og-image.png' />

		<link rel='canonical' href='https://sarmal.art/' />
	</head>
	<body class='min-h-screen'>
		<header class='w-full px-4 py-3 flex items-center justify-between border-b border-border'>
			<a href='/' class='font-heading text-lg text-foreground hover:text-primary transition-colors'>
				<span class='text-primary'>sarmal</span>.art
			</a>
			<a
				href='https://github.com/yethranayeh/sarmal'
				target='_blank'
				rel='noopener noreferrer'
				class='font-mono text-xs tracking-wider uppercase text-muted hover:text-foreground transition-colors'>
				GitHub
			</a>
		</header>

		<main class='max-w-3xl mx-auto p-4'>
			<section class='text-center mb-16'>
				<div class='flex justify-center mb-6'>
					<Sarmal curve='artemis2' width={200} height={130} trailColor='#60a5fa' trailLength={300} />
				</div>
				<h1 class='font-heading italic text-4xl md:text-5xl leading-tight tracking-tight text-foreground mb-3'>
					Loading <span class='text-primary'>Artemis II</span>
				</h1>
				<p class='font-body text-base text-muted max-w-sm mx-auto mb-8'>
					A spinner tracing humanity's return to <span class='text-primary'>the Moon</span>. <em>The first</em> crewed lunar
					flight since <span class='text-primary'>Apollo 17</span>.
				</p>

				<div class='flex flex-col justify-start max-w-md mx-auto'>
					<div class='flex justify-start mb-3'>
						<SectionLabel label='Two lines of HTML' />
					</div>
					<div class='bg-surface border border-border rounded-md text-left'>
						<Code
							class='p-2'
							code={`<script src="https://unpkg.com/@sarmal/core/dist/auto-init.js"></script>

<canvas
  data-sarmal="artemis2"
  data-trail-color="#60a5fa"
  data-skeleton-color="#60a5fa"></canvas>`}
							lang='html'
							theme='slack-ochin'
						/>
					</div>
				</div>
			</section>

			<section>
				<h2 class='font-heading text-xl text-center text-foreground mb-6'>Standard sarmals</h2>
				<div class='grid grid-cols-3 md:grid-cols-5 gap-4'>
					{
						sarmals.map((curve) => (
							<div class='flex flex-col items-center'>
								<div title={curve.id} class='bg-surface border border-border rounded-md p-3 mb-2 overflow-visible'>
									<Sarmal curve={curve.id} width={72} height={72} trailColor={curve.color} />
								</div>
								<span title={curve.id} class='font-mono text-[10px] tracking-wider uppercase text-muted'>
									{curve.name}
								</span>
							</div>
						))
					}
				</div>
			</section>
		</main>

		<footer class='w-full px-4 py-6 border-t border-border text-center'>
			<p class='font-mono text-[10px] tracking-wider uppercase text-muted'>2.75 KB gzipped · MIT License · © 2026</p>
		</footer>
	</body>
</html>
