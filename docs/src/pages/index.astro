---
import BaseLayout from "../layouts/BaseLayout.astro";

import HeroSection from "../components/feature/HeroSection.astro";
import LiveDemoContainer from "../components/feature/demo/LiveDemoContainer.astro";

import { PACKAGE_SIZE } from "../variables";
---

<BaseLayout
	title="Sarmal - Parametric Curve Animations for React & JavaScript"
	description={`Parametric loading spinners and curve animations for React, JavaScript, and the web. ${PACKAGE_SIZE}KB, zero dependencies. A curve, a color, two lines of code.`}
	ogTitle="Sarmal | Parametric Curve Animations for React & JavaScript"
>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			name: "Sarmal",
			applicationCategory: "DeveloperApplication",
			operatingSystem: "Any",
			description: `Beautiful parametric loading indicators. ${PACKAGE_SIZE}KB, zero dependencies. A curve, a color, two lines of HTML.`,
			url: "https://sarmal.art",
			offers: {
				"@type": "Offer",
				price: "0",
				priceCurrency: "USD",
			},
		})}
	/>
	<main class="w-full space-y-4 md:space-y-16">
		<HeroSection />

		<LiveDemoContainer />
	</main>
</BaseLayout>
