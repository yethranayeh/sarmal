---
import BaseLayout from "../layouts/BaseLayout.astro";
import Link from "../components/Link.astro";
---

<BaseLayout title='Documentation - Sarmal' description='API reference, examples, and guides for @sarmal/core'>
	<main class='flex min-h-screen flex-col items-center justify-center px-4 text-center'>
		<h1 class='text-4xl font-bold'>Documentation</h1>
		<p class='mt-4 text-lg text-muted'>
			Work in progress. In the meantime, check out the
			<Link href='https://github.com/yethranayeh/sarmal' external>README</Link>
			or explore the <Link href='/'>homepage</Link>.
		</p>
	</main>
</BaseLayout>
