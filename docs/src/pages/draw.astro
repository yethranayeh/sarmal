---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Toggle from "../components/Toggle.astro";
import { SEPARATOR_DOT } from "../variables";
import { Copy, Trash2 } from "@lucide/astro";

---

<BaseLayout
	title={`Draw ${SEPARATOR_DOT} Sarmal`}
	description='Draw your own curves by dragging nodes and generate code for your project.'>

	<main class='flex flex-col lg:flex-row h-[calc(100vh-57px)]'>
		<!-- Left Panel: Controls & Code -->
		<section class='w-full lg:w-1/3 flex flex-col border-b lg:border-b-0 lg:border-r border-border bg-surface overflow-hidden'>
			<div class='flex items-center justify-between px-4 py-2 border-b border-border-subtle bg-surface'>
				<span class='font-mono text-xs tracking-wider uppercase text-muted'>Sarmal Draw</span>
				<div class='flex items-center gap-2'>
					<Button id='clear-btn' variant='primary' hoverColor='error' size="sm">
						<Trash2 slot='icon' class='w-3.5 h-3.5' />
						Clear
					</Button>
				</div>
			</div>

			<div class='flex-1 p-4 overflow-auto space-y-6'>
				<!-- Instructions -->
				<div class='bg-surface-raised border border-border rounded-md p-3'>
					<h3 class='font-mono text-[10px] tracking-wider uppercase text-primary mb-2'>Instructions</h3>
					<ul class='font-mono text-[10px] text-muted space-y-1 list-disc list-inside'>
						<li>Click on the grid to add a node</li>
						<li>Drag nodes to reshape the curve</li>
						<li>Right-click a node to remove it</li>
					</ul>
				</div>

				<!-- Settings -->
				<div class='space-y-4'>
					<Toggle id='skeleton-toggle' label='Show Preview Skeleton' checked={true} />

					<div class='flex items-center gap-2'>
						<label for='speed-slider' class='font-mono text-[10px] tracking-wider uppercase text-muted w-24 shrink-0'>Speed</label>
						<input type='range' id='speed-slider' min='0.1' max='5' step='0.1' value='1.1' class='flex-1 min-w-0 accent-primary' />
						<span id='speed-value' class='font-mono text-[10px] text-muted w-7 text-right tabular-nums'>1.1</span>
					</div>

					<div class='flex items-center gap-2'>
						<label for='trail-slider' class='font-mono text-[10px] tracking-wider uppercase text-muted w-24 shrink-0'>Trail</label>
						<input type='range' id='trail-slider' min='10' max='500' step='10' value='120' class='flex-1 min-w-0 accent-primary' />
						<span id='trail-value' class='font-mono text-[10px] text-muted w-7 text-right tabular-nums'>120</span>
					</div>

					<div class='grid grid-cols-2 gap-3'>
						<div class='flex flex-col gap-1'>
							<label for='trail-style-select' class='font-mono text-[10px] tracking-wider uppercase text-muted'>Style</label>
							<select
								id='trail-style-select'
								class='w-full font-mono text-xs bg-surface-raised border border-border rounded px-2 py-1 text-foreground cursor-pointer hover:border-primary transition-colors'>
								<option value='default'>Default</option>
								<option value='gradient-static'>Static Gradient</option>
								<option value='gradient-animated'>Animated</option>
							</select>
						</div>

						<div class='flex flex-col gap-1'>
							<label for='color-input' class='font-mono text-[10px] tracking-wider uppercase text-muted'>Color</label>
							<input type='color' id='color-input' value='#a78bfa' class='w-full h-7 cursor-pointer' />
						</div>

						<div class='flex flex-col gap-1 hidden'>
							<label for='palette-select' class='font-mono text-[10px] tracking-wider uppercase text-muted'>Palette</label>
							<select
								id='palette-select'
								class='w-full font-mono text-xs bg-surface-raised border border-border rounded px-2 py-1 text-foreground cursor-pointer hover:border-primary transition-colors'>
								<option value='bard'>Bard</option>
								<option value='sunset'>Sunset</option>
								<option value='ocean'>Ocean</option>
								<option value='ice'>Ice</option>
								<option value='fire'>Fire</option>
								<option value='forest'>Forest</option>
							</select>
						</div>
					</div>
				</div>

				<!-- Code Export -->
				<div class='space-y-2'>
					<div class='flex items-center justify-between'>
						<h3 class='font-mono text-[10px] tracking-wider uppercase text-muted'>Generated HTML Tag</h3>
						<Button id='copy-btn' variant='ghost' size='sm'>
							<Copy class='w-3 h-3 mr-1.5' />
							Copy
						</Button>
					</div>
					<pre id='code-output' class='p-3 bg-surface-raised border border-border rounded-md font-mono text-[11px] overflow-x-auto text-foreground whitespace-pre'></pre>
				</div>

				<!-- Quick Start Guide -->
				<div class='bg-primary/5 border border-primary/20 rounded-md p-3 space-y-3'>
					<h3 class='font-mono text-[10px] tracking-wider uppercase text-primary'>How to use this</h3>
					<div class='space-y-2'>
						<div class='flex gap-2 items-start'>
							<span class='w-4 h-4 rounded-full bg-primary text-white text-[10px] flex items-center justify-center shrink-0 mt-0.5'>1</span>
							<p class='font-mono text-[10px] text-muted'>Include the Sarmal script in your &lt;head&gt; or &lt;body&gt;:</p>
						</div>
						<pre class='p-2 bg-surface border border-border rounded text-[9px] overflow-x-auto'>&lt;script src="https://unpkg.com/@sarmal/core"&gt;&lt;/script&gt;</pre>
						
						<div class='flex gap-2 items-start'>
							<span class='w-4 h-4 rounded-full bg-primary text-white text-[10px] flex items-center justify-center shrink-0 mt-0.5'>2</span>
							<p class='font-mono text-[10px] text-muted'>Paste the <b>Generated HTML Tag</b> above into your page where you want the animation to appear.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Right Panel: Editor & Preview -->
		<section class='flex-1 flex flex-col bg-background relative overflow-hidden'>
			<!-- Grid Overlay -->
			<div class='absolute inset-0 bg-[radial-gradient(#d0cec9_1.5px,transparent_1.5px)] bg-size-[24px_24px] opacity-40 pointer-events-none'></div>
			
			<div class='flex-1 grid grid-cols-1 lg:grid-cols-2 gap-8 p-8 relative z-10'>
				<!-- Draw Area -->
				<div class='flex flex-col gap-4'>
					<h2 class='font-mono text-xs tracking-widest uppercase text-muted text-center'>Draw Path</h2>
					<div class='relative aspect-square w-full max-w-lg mx-auto bg-surface-raised border border-border rounded-xl shadow-2xl overflow-hidden cursor-crosshair'>
						<canvas id='draw-canvas' width='400' height='400' class='w-full h-full'></canvas>
					</div>
				</div>

				<!-- Preview Area -->
				<div class='flex flex-col gap-4'>
					<h2 class='font-mono text-xs tracking-widest uppercase text-muted text-center'>Live Preview</h2>
					<div class='relative aspect-square w-full max-w-lg mx-auto bg-surface-raised border border-border rounded-xl shadow-2xl overflow-hidden'>
						<canvas id='preview-canvas' width='400' height='400' class='w-full h-full'></canvas>
					</div>
				</div>
			</div>
		</section>
	</main>

	<script src="../draw.ts"></script>
</BaseLayout>
