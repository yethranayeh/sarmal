---
import { curves } from "@sarmal/core";

import BaseLayout from "../layouts/BaseLayout.astro";
import Playground from "../Playground.svelte";

import { SEPARATOR_DOT } from "../variables";
import { CURVE_DOCS, type CurveUrlId } from "../data/curves";

const curveEntries = Object.entries(curves)
	.filter(([id]) => CURVE_DOCS[id as CurveUrlId]?.kind !== "drawn")
	.map(([id, def]) => ({
		id,
		name: def.name,
		fn: def.fn.toString(),
		period: def.period ?? Math.PI * 2,
	}));
---

<BaseLayout
	title={`Playground ${SEPARATOR_DOT} Sarmal`}
	description="Type math, see it follow a path. Create your own sarmal loading indicators."
>
	<div class="flex-1">
		<Playground client:only="svelte" presets={curveEntries} />
	</div>
</BaseLayout>
