---
import { curves } from "@sarmal/core";
import { Share2, Trash2 } from "@lucide/astro";

import BaseLayout from "../layouts/BaseLayout.astro";
import Toggle from "../components/Toggle.astro";
import Button from "../components/Button.astro";

import { SEPARATOR_DOT } from "../variables";

const curveEntries = Object.entries(curves).map(([id, def]) => ({
	id,
	name: def.name,
	fn: def.fn.toString()
}));

const DEFAULT_CODE = `return {
  x: Math.cos(t),
  y: Math.sin(t)
}`;

const presetsJson = JSON.stringify(
	curveEntries.map((c) => ({
		id: c.id,
		name: c.name,
		fn: c.fn
	}))
);
---

<BaseLayout
	title={`Play ${SEPARATOR_DOT} Sarmal`}
	description='Type math, see it follow a path. Create your own sarmal loading indicators.'>

	<main class='flex flex-col lg:flex-row h-[calc(100vh-57px)]'>
		<section class='w-full lg:w-1/2 flex flex-col border-b lg:border-b-0 lg:border-r border-border'>
			<div class='flex items-center justify-between px-4 py-2 border-b border-border-subtle bg-surface'>
				<div class='flex items-center gap-3'>
					<span class='font-mono text-xs tracking-wider uppercase text-muted'>Editor</span>
					<select
						id='preset-select'
						class='font-mono text-xs bg-transparent border border-border rounded px-2 py-1 text-foreground cursor-pointer hover:border-primary transition-colors'>
						<option value=''>Select a curve</option>
						{curveEntries.map((curve) => <option value={curve.id}>{curve.name}</option>)}
					</select>
				</div>
				<div class='flex items-center gap-3'>
					<div class='relative'>
					<Button id='share-btn' variant="ghost">
						<Share2 slot='icon' class='w-3.5 h-3.5' />
						Share
					</Button>
						<span
							id='share-status'
							class='hidden absolute right-0 top-6 whitespace-nowrap font-mono text-[10px] text-muted bg-surface border border-border rounded px-2 py-1 z-10'>
						</span>
					</div>
					<Button id='clear-btn' variant='primary' hoverColor='error'>
						<Trash2 slot='icon' class='w-3.5 h-3.5' />
						Clear
					</Button>
				</div>
			</div>

			<div class='flex-1 p-4 overflow-auto'>
				<div class='mb-3'>
					<label for='code-input' class='block font-mono text-[10px] tracking-wider text-muted mb-1'>
						<span class='text-muted'
							>function (<span></span><code title='parametric angle (0 -> period)' class='text-primary'>t</code><span
								class='text-muted'>:</span
							><span class='text-muted'>number</span><span class='text-muted'> </span>,
						</span><code title='elapsed time in seconds' class='text-primary'>time</code><span class='text-muted'
							>:</span
						><span class='text-muted'>number</span><span class='text-muted'>, </span><code
							title='custom parameters object'
							class='text-primary'>params</code
						><span class='text-muted'>:</span><span class='text-muted'>{`Record<string, number>;`}</span><span
							class='text-muted'>) {"{"}</span
						>
					</label>
					<textarea
						id='code-input'
						class='w-full h-48 font-mono text-sm bg-surface-raised border border-border rounded-md p-3 text-foreground resize-none focus:outline-none focus:border-primary transition-colors'
						>{DEFAULT_CODE}</textarea
					>
					<div id='error-display' class='hidden mt-2 font-mono text-xs text-error'></div>
					<p class='mt-2 font-mono text-[10px] text-muted'>{"}"}</p>
				</div>

				<div class='space-y-4'>
					<Toggle id='skeleton-toggle' label='Skeleton' checked={true} />

					<div>
						<div class='flex items-center justify-between mb-1'>
							<label for='speed-slider' class='font-mono text-xs tracking-wider uppercase text-muted'> Speed </label>
							<span id='speed-value' class='font-mono text-xs text-muted'>1.0</span>
						</div>
						<input
							type='range'
							id='speed-slider'
							min='0.1'
							max='5'
							step='0.1'
							value='1'
							class='w-full accent-primary'
						/>
					</div>

					<div>
						<div class='flex items-center justify-between mb-1'>
							<label for='trail-slider' class='font-mono text-xs tracking-wider uppercase text-muted'>
								Trail Length
							</label>
							<span id='trail-value' class='font-mono text-xs text-muted'>120</span>
						</div>
						<input
							type='range'
							id='trail-slider'
							min='10'
							max='500'
							step='10'
							value='120'
							class='w-full accent-primary'
						/>
					</div>

					<div>
						<div class='flex items-center justify-between mb-1'>
							<label for='color-input' class='font-mono text-xs tracking-wider uppercase text-muted'>
								Trail Color
							</label>
							<input
								type='color'
								id='color-input'
								value='#c0143c'
								class='w-8 h-5 rounded border border-border cursor-pointer'
							/>
						</div>
					</div>

					<div>
						<div class='flex items-center justify-between mb-1'>
							<label for='head-color-input' class='font-mono text-xs tracking-wider uppercase text-muted'>
								Head Color
							</label>
							<div class='flex items-center gap-2'>
								<label class='flex items-center gap-1 cursor-pointer'>
									<input
										type='checkbox'
										id='head-color-auto'
										checked
										class='accent-primary'
									/>
									<span class='font-mono text-[10px] text-muted'>Auto</span>
								</label>
								<input
									type='color'
									id='head-color-input'
									value='#c0143c'
									class='w-8 h-5 rounded border border-border cursor-pointer'
									disabled
								/>
							</div>
						</div>
					</div>

					<div>
						<div class='flex items-center justify-between mb-1'>
							<label for='trail-style-select' class='font-mono text-xs tracking-wider uppercase text-muted'>
								Trail Style
							</label>
						</div>
						<select
							id='trail-style-select'
							class='w-full font-mono text-xs bg-transparent border border-border rounded px-2 py-1 text-foreground cursor-pointer hover:border-primary transition-colors'>
							<option value='default'>Default (white fade)</option>
							<option value='gradient-static'>Static Gradient</option>
							<option value='gradient-animated'>Animated Gradient</option>
						</select>
					</div>

					<div id='palette-container' class='hidden'>
						<div class='flex items-center justify-between mb-1'>
							<label for='palette-select' class='font-mono text-xs tracking-wider uppercase text-muted'>
								Palette
							</label>
						</div>
						<select
							id='palette-select'
							class='w-full font-mono text-xs bg-transparent border border-border rounded px-2 py-1 text-foreground cursor-pointer hover:border-primary transition-colors'>
							<option value='bard'>Bard (purple, blue, teal, pink)</option>
							<option value='sunset'>Sunset (orange, red, purple, pink)</option>
							<option value='ocean'>Ocean (deep blue, cyan, aqua, white)</option>
							<option value='ice'>Ice (deep blue, ice cyan)</option>
							<option value='fire'>Fire (deep red, amber)</option>
							<option value='forest'>Forest (deep green, mint)</option>
						</select>
					</div>
				</div>
			</div>
		</section>

		<section class='w-full lg:w-1/2 flex items-center justify-center bg-background p-4 relative'>
			<!-- <div class='absolute inset-0 bg-[radial-gradient(#000_1.5px,transparent_1.5px)] bg-size-[24px_24px]'></div> -->
			<div class='absolute inset-0 bg-[radial-gradient(#d0cec9_1.5px,transparent_1.5px)] bg-size-[24px_24px] opacity-60'></div>
			<div class='relative w-full max-w-md aspect-square'>
				<canvas id='preview-canvas' width='400' height='400' class='w-full h-full'></canvas>
			</div>
		</section>

		<script is:inline type='application/json' id='presets-data' set:html={presetsJson}>
		</script>
		<script src='../play.ts'></script>
	</main>
</BaseLayout>
