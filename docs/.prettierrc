{
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-astro"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "useTabs": false,
        "singleQuote": false
      }
    }
  ],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": true,
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true
}
